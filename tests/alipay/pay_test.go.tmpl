package alipay

import (
    "net/http"
    "net/http/httptest"
    "testing"

    "github.com/gin-gonic/gin"
)

func TestE2EPayFlow(t *testing.T) {
    gin.SetMode(gin.TestMode)

    router := gin.Default()
    mockClient := &MockOrderRpcClient{}
    handler := NewOrderHandler(mockClient)
    router.POST("/api/order/pay", handler.GeneratePayURL)
    router.POST("/api/order/notify", handler.HandleNotify)

    ts := httptest.NewServer(router)
    defer ts.Close()

    resp, err := http.Post(ts.URL+"/api/order/pay", "application/json", nil)
    if err != nil {
        t.Fatal(err)
    }
    defer resp.Body.Close()

    if resp.StatusCode != http.StatusOK {
        t.Errorf("expected 200, got %d", resp.StatusCode)
    }
}
