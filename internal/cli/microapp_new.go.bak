	case "1tn":
		// 一对多 - 使用模板
		getTmplPath := filepath.Join(getTemplatesDir(), "micro-app", "join", "service", "get_1tn.go.tmpl")
		getTmplBytes, err := os.ReadFile(getTmplPath)
		if err != nil {
			fmt.Printf("Error reading template: %v\n", err)
