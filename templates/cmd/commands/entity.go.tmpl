// {{.EntityNameLower}}Cmd represents the {{.EntityNameLower}} command
var {{.EntityNameLower}}Cmd = &cobra.Command{
	Use:   "{{.EntityNameLower}}",
	Short: "{{.EntityName}} management",
	Long:  `{{.EntityName}} management commands`,
}

var {{.EntityNameLower}}ListCmd = &cobra.Command{
	Use:   "list",
	Short: "List {{.EntityName}}s",
	Run: func(cmd *cobra.Command, args []string) {
		ctx := context.Background()
		handler := handler.New{{.EntityName}}Handler(ctx)
		
