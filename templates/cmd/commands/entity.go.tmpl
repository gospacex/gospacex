		pageSize := 10
		
		resp, total, err := handler.List{{.EntityName}}(page, pageSize)
		if err != nil {
			fmt.Printf("Error: %v\n", err)
			return
		}
		
		handler.Print{{.EntityName}}s(resp, total, page, pageSize)
	},
}

