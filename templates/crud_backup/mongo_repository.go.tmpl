package repository

import (
	"context"
	"fmt"
	"time"

	"go.mongodb.org/mongo-driver/bson"
	"go.mongodb.org/mongo-driver/bson/primitive"
	"go.mongodb.org/mongo-driver/mongo"
	"go.mongodb.org/mongo-driver/mongo/options"
)

// {{.StructName}}Repository MongoDB {{.StructName}} 仓储
type {{.StructName}}Repository struct {
	collection *mongo.Collection
}

// New{{.StructName}}Repository creates new {{.StructName}} repository
func New{{.StructName}}Repository(db *mongo.Database) *{{.StructName}}Repository {
	return &{{.StructName}}Repository{
		collection: db.Collection("{{.LowerName}}"),
	}
}

// Insert inserts {{.StructName}} to MongoDB
func (r *{{.StructName}}Repository) Insert(ctx context.Context, entity *{{.StructName}}) error {
	entity.CreatedAt = time.Now()
	entity.UpdatedAt = time.Now()
	
	result, err := r.collection.InsertOne(ctx, entity)
	if err != nil {
		return err
	}
	
	entity.ID = result.InsertedID.(primitive.ObjectID)
	return nil
}

// GetByID gets {{.StructName}} from MongoDB by ID
func (r *{{.StructName}}Repository) GetByID(ctx context.Context, id string) (*{{.StructName}}, error) {
	objectID, err := primitive.ObjectIDFromHex(id)
	if err != nil {
		return nil, err
	}

	var entity {{.StructName}}
	err = r.collection.FindOne(ctx, bson.M{"_id": objectID}).Decode(&entity)
	if err != nil {
		if err == mongo.ErrNoDocuments {
			return nil, fmt.Errorf("{{.LowerName}} not found")
		}
		return nil, err
	}

	return &entity, nil
}

// Find finds {{.StructName}} in MongoDB with filter
func (r *{{.StructName}}Repository) Find(ctx context.Context, filter bson.M, opts ...*options.FindOptions) ([]{{.StructName}}, error) {
	if opts == nil {
		opts = []*options.FindOptions{options.Find()}
	}

	cursor, err := r.collection.Find(ctx, filter, opts...)
	if err != nil {
		return nil, err
	}
	defer cursor.Close(ctx)

	var entities []{{.StructName}}
	if err := cursor.All(ctx, &entities); err != nil {
		return nil, err
	}

	return entities, nil
}

// List lists {{.StructName}} from MongoDB
func (r *{{.StructName}}Repository) List(ctx context.Context, offset, limit int64) ([]{{.StructName}}, error) {
	opts := options.Find()
	opts.SetSkip(offset)
	opts.SetLimit(limit)
	opts.SetSort(bson.D{{Key: "created_at", Value: -1}})

	filter := bson.M{}
	return r.Find(ctx, filter, opts)
}

// Update updates {{.StructName}} in MongoDB
func (r *{{.StructName}}Repository) Update(ctx context.Context, id string, entity *{{.StructName}}) error {
	objectID, err := primitive.ObjectIDFromHex(id)
	if err != nil {
		return err
	}

	entity.UpdatedAt = time.Now()
	
	update := bson.M{
		"$set": entity,
	}

	_, err = r.collection.UpdateOne(ctx, bson.M{"_id": objectID}, update)
	return err
}

// UpdateByID updates {{.StructName}} by ID using atomic operators
func (r *{{.StructName}}Repository) UpdateByID(ctx context.Context, id string, update bson.M) error {
	objectID, err := primitive.ObjectIDFromHex(id)
	if err != nil {
		return err
	}

	update["$set"] = bson.M{"updated_at": time.Now()}
	
	_, err = r.collection.UpdateOne(ctx, bson.M{"_id": objectID}, update)
	return err
}

// Delete deletes {{.StructName}} from MongoDB
func (r *{{.StructName}}Repository) Delete(ctx context.Context, id string) error {
	objectID, err := primitive.ObjectIDFromHex(id)
	if err != nil {
		return err
	}

	_, err = r.collection.DeleteOne(ctx, bson.M{"_id": objectID})
	return err
}

// DeleteMany deletes multiple {{.StructName}} from MongoDB
func (r *{{.StructName}}Repository) DeleteMany(ctx context.Context, filter bson.M) (int64, error) {
	result, err := r.collection.DeleteMany(ctx, filter)
	if err != nil {
		return 0, err
	}
	return result.DeletedCount, nil
}

// Count counts {{.StructName}} in MongoDB
func (r *{{.StructName}}Repository) Count(ctx context.Context, filter ...bson.M) (int64, error) {
	var f bson.M
	if len(filter) > 0 {
		f = filter[0]
	} else {
		f = bson.M{}
	}

	count, err := r.collection.CountDocuments(ctx, f)
	if err != nil {
		return 0, err
	}
	return count, nil
}

// Aggregate performs aggregation on {{.StructName}}
func (r *{{.StructName}}Repository) Aggregate(ctx context.Context, pipeline mongo.Pipeline) ([]bson.M, error) {
	cursor, err := r.collection.Aggregate(ctx, pipeline)
	if err != nil {
		return nil, err
	}
	defer cursor.Close(ctx)

	var results []bson.M
	if err := cursor.All(ctx, &results); err != nil {
		return nil, err
	}

	return results, nil
}

// CreateIndex creates index on {{.StructName}}
func (r *{{.StructName}}Repository) CreateIndex(ctx context.Context, fields ...string) error {
	indexModels := make([]mongo.IndexModel, len(fields))
	for i, field := range fields {
		indexModels[i] = mongo.IndexModel{
			Keys: bson.D{{Key: field, Value: 1}},
		}
	}

	_, err := r.collection.Indexes().CreateMany(ctx, indexModels)
	return err
}

// DropIndex drops index on {{.StructName}}
func (r *{{.StructName}}Repository) DropIndex(ctx context.Context, fields ...string) error {
	_, err := r.collection.Indexes().DropAll(ctx)
	return err
}

