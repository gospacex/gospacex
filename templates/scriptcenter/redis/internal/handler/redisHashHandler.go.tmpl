package handler

import (
	"context"

	"github.com/redis/go-redis/v9"
)

type HashHandler struct {
	client *redis.Client
}

func NewHashHandler(client *redis.Client) *HashHandler {
	return &HashHandler{client: client}
}

func (h *HashHandler) HSet(ctx context.Context, key, field, value string) error {
	return h.client.HSet(ctx, key, field, value).Err()
}

func (h *HashHandler) HGet(ctx context.Context, key, field string) (string, error) {
	return h.client.HGet(ctx, key, field).Result()
}

func (h *HashHandler) HGetAll(ctx context.Context, key string) (map[string]string, error) {
	return h.client.HGetAll(ctx, key).Result()
}

func (h *HashHandler) HMSet(ctx context.Context, key string, fields map[string]interface{}) error {
	return h.client.HMSet(ctx, key, fields).Err()
}

func (h *HashHandler) HMGet(ctx context.Context, key string, fields ...string) ([]interface{}, error) {
	return h.client.HMGet(ctx, key, fields...).Result()
}

func (h *HashHandler) HDel(ctx context.Context, key string, fields ...string) error {
	return h.client.HDel(ctx, key, fields...).Err()
}

func (h *HashHandler) HExists(ctx context.Context, key, field string) (bool, error) {
	return h.client.HExists(ctx, key, field).Result()
}

func (h *HashHandler) HLen(ctx context.Context, key string) (int64, error) {
	return h.client.HLen(ctx, key).Result()
}

func (h *HashHandler) HKeys(ctx context.Context, key string) ([]string, error) {
	return h.client.HKeys(ctx, key).Result()
}

func (h *HashHandler) HVals(ctx context.Context, key string) ([]string, error) {
	return h.client.HVals(ctx, key).Result()
}