package handler

import (
	"context"

	"github.com/redis/go-redis/v9"
)

type ZSetHandler struct {
	client *redis.Client
}

func NewZSetHandler(client *redis.Client) *ZSetHandler {
	return &ZSetHandler{client: client}
}

func (h *ZSetHandler) ZAdd(ctx context.Context, key string, members ...redis.Z) error {
	return h.client.ZAdd(ctx, key, members...).Err()
}

func (h *ZSetHandler) ZRange(ctx context.Context, key string, start, stop int64) ([]string, error) {
	return h.client.ZRange(ctx, key, start, stop).Result()
}

func (h *ZSetHandler) ZRangeWithScores(ctx context.Context, key string, start, stop int64) ([]redis.Z, error) {
	return h.client.ZRangeWithScores(ctx, key, start, stop).Result()
}

func (h *ZSetHandler) ZRevRange(ctx context.Context, key string, start, stop int64) ([]string, error) {
	return h.client.ZRevRange(ctx, key, start, stop).Result()
}

func (h *ZSetHandler) ZRevRangeWithScores(ctx context.Context, key string, start, stop int64) ([]redis.Z, error) {
	return h.client.ZRevRangeWithScores(ctx, key, start, stop).Result()
}

func (h *ZSetHandler) ZRank(ctx context.Context, key, member string) (int64, error) {
	return h.client.ZRank(ctx, key, member).Result()
}

func (h *ZSetHandler) ZRevRank(ctx context.Context, key, member string) (int64, error) {
	return h.client.ZRevRank(ctx, key, member).Result()
}

func (h *ZSetHandler) ZScore(ctx context.Context, key, member string) (float64, error) {
	return h.client.ZScore(ctx, key, member).Result()
}

func (h *ZSetHandler) ZRem(ctx context.Context, key string, members ...interface{}) error {
	return h.client.ZRem(ctx, key, members...).Err()
}

func (h *ZSetHandler) ZCount(ctx context.Context, key string, min, max float64) (int64, error) {
	return h.client.ZCount(ctx, key, min, max).Result()
}

func (h *ZSetHandler) ZCard(ctx context.Context, key string) (int64, error) {
	return h.client.ZCard(ctx, key).Result()
}

func (h *ZSetHandler) ZRangeByScore(ctx context.Context, key string, opt *redis.ZRangeBy) ([]string, error) {
	return h.client.ZRangeByScore(ctx, key, opt).Result()
}