package service

import (
	"context"

	"{{.ProjectName}}/internal/model"
	"{{.ProjectName}}/internal/repository"
	"{{.ProjectName}}/internal/mq"
)

// EbArticleService 文章服务接口
type EbArticleService interface {
	Create(ctx context.Context, article *model.EbArticle) error
	GetByID(ctx context.Context, id int64) (*model.EbArticle, error)
	Store(ctx context.Context, article *model.EbArticle) error
	List(ctx context.Context, page, size int) ([]*model.EbArticle, int64, error)
	Update(ctx context.Context, article *model.EbArticle) error
	Delete(ctx context.Context, id int64) error
}

type ebArticleService struct {
	repo    repository.EbArticleRepository
	producer *mq.KafkaProducer
}

// NewEbArticleService 创建服务
func NewEbArticleService() *ebArticleService {
	// repo will be injected with database connection
	return &ebArticleService{}
}

// Create creates and publishes article to Kafka
func (s *ebArticleService) Create(ctx context.Context, article *model.EbArticle) error {
	// Save to database first
	if err := s.repo.Create(ctx, article); err != nil {
		return err
	}

	// Then publish to Kafka
	if s.producer != nil {
		if err := s.producer.Publish(ctx, article); err != nil {
			return err
		}
	}

	return nil
}

// GetByID gets article by ID
func (s *ebArticleService) GetByID(ctx context.Context, id int64) (*model.EbArticle, error) {
	return s.repo.GetByID(ctx, id)
}

// Store stores article from Kafka consumer
func (s *ebArticleService) Store(ctx context.Context, article *model.EbArticle) error {
	return s.repo.Create(ctx, article)
}

// List lists articles
func (s *ebArticleService) List(ctx context.Context, page, size int) ([]*model.EbArticle, int64, error) {
	offset := (page - 1) * size
	return s.repo.List(ctx, offset, size)
}

// Update updates article
func (s *ebArticleService) Update(ctx context.Context, article *model.EbArticle) error {
	return s.repo.Update(ctx, article)
}

// Delete deletes article
func (s *ebArticleService) Delete(ctx context.Context, id int64) error {
	return s.repo.Delete(ctx, id)
}

