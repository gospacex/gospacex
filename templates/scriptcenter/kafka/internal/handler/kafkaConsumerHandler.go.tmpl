package handler

import (
	"context"
	"log"

	"{{.ProjectName}}/internal/mq"
	"{{.ProjectName}}/internal/model"
	"{{.ProjectName}}/internal/service"
)

// KafkaConsumerHandler Kafka 消息消费者处理器
type KafkaConsumerHandler struct {
	consumer  *mq.KafkaConsumer
	service   service.EbArticleService
}

// NewKafkaConsumerHandler 创建处理器
func NewKafkaConsumerHandler(consumer *mq.KafkaConsumer, svc service.EbArticleService) *KafkaConsumerHandler {
	return &KafkaConsumerHandler{
		consumer:  consumer,
		service:   svc,
	}
}

// Start 开始消费
func (h *KafkaConsumerHandler) Start(ctx context.Context) error {
	log.Println("Starting Kafka consumer...")
	return h.consumer.Consume(ctx, func(article *model.EbArticle) error {
		log.Printf("Received article: %s", article.Name)
		// 这里处理消息 - 保存到数据库
		if err := h.service.Store(ctx, article); err != nil {
			log.Printf("Error storing article: %v", err)
			return err
		}
		log.Printf("Article stored successfully")
		return nil
	})
}
