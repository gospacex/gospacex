package mq

import (
	"fmt"

	"github.com/segmentio/kafka-go"
)

// KafkaClient Kafka 客户端封装
type KafkaClient struct {
	brokers []string
}

// NewKafkaClient 创建客户端
func NewKafkaClient(brokers []string) *KafkaClient {
	return &KafkaClient{
		brokers: brokers,
	}
}

// IsHealthy 检查连接健康
func (c *KafkaClient) IsHealthy() error {
	// Simple connection check by listing brokers
	for _, broker := range c.brokers {
		conn, err := kafka.Dial("tcp", broker)
		if err != nil {
			return fmt.Errorf("failed to connect to broker %s: %w", broker, err)
		}
		defer conn.Close()

		_, err = conn.Brokers()
		if err != nil {
			return fmt.Errorf("failed to get brokers from %s: %w", broker, err)
		}
	}
	return nil
}
