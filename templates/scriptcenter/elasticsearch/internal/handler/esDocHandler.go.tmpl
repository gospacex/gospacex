package handler

import (
	"context"
	"fmt"

	"{{.ProjectName}}/internal/model"
	"{{.ProjectName}}/internal/search"
)

// EsDocHandler Elasticsearch 文档处理器
type EsDocHandler struct {
	client *search.EsClient
}

// NewEsDocHandler 创建处理器
func NewEsDocHandler(client *search.EsClient) *EsDocHandler {
	return &EsDocHandler{
		client: client,
	}
}

// GetByID 根据 ID 获取文档
func (h *EsDocHandler) GetByID(ctx context.Context, id int64) (*model.EbArticle, error) {
	return h.client.GetByID(ctx, id)
}

// Search 搜索文档
func (h *EsDocHandler) Search(ctx context.Context, keyword string) ([]*model.EbArticle, int64, error) {
	return h.client.Search(ctx, keyword)
}
