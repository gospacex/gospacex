package repository

import (
	"context"
	"fmt"

	"{{.ProjectName}}/internal/model"
	"{{.ProjectName}}/internal/search"
	"gorm.io/gorm"
)

// EbArticleRepository 文章仓储（包含 Elasticsearch 索引）
type EbArticleRepository struct {
	db    *gorm.DB
	es    *search.EsClient
	index string
}

// NewEbArticleRepository 创建仓储
func NewEbArticleRepository(db *gorm.DB, es *search.EsClient, index string) *EbArticleRepository {
	return &EbArticleRepository{
		db:    db,
		es:    es,
		index: index,
	}
}

// Create 创建文章并索引到 Elasticsearch
func (r *EbArticleRepository) Create(ctx context.Context, article *model.EbArticle) error {
	// 先保存到 MySQL
	if err := r.db.WithContext(ctx).Create(article).Error; err != nil {
		return err
	}

	// 然后索引到 Elasticsearch
	if err := r.es.IndexArticle(ctx, article); err != nil {
		return fmt.Errorf("index to elasticsearch failed: %w", err)
	}

	return nil
}

// GetByID 获取文章
func (r *EbArticleRepository) GetByID(ctx context.Context, id int64) (*model.EbArticle, error) {
	var article model.EbArticle
	err := r.db.WithContext(ctx).Where("id = ?", id).First(&article).Error
	if err != nil {
		return nil, err
	}
	return &article, nil
}

// List 列表查询
func (r *EbArticleRepository) List(ctx context.Context, offset, limit int) ([]*model.EbArticle, int64, error) {
	var articles []*model.EbArticle
	var count int64

	err := r.db.WithContext(ctx).Model(&model.EbArticle{}).Count(&count).Error
	if err != nil {
		return nil, 0, err
	}

	err = r.db.WithContext(ctx).Offset(offset).Limit(limit).Find(&articles).Error
	if err != nil {
		return nil, 0, err
	}

	return articles, count, nil
}

// Update 更新文章
func (r *EbArticleRepository) Update(ctx context.Context, article *model.EbArticle) error {
	return r.db.WithContext(ctx).Save(article).Error
}

// Delete 删除文章
func (r *EbArticleRepository) Delete(ctx context.Context, id int64) error {
	return r.db.WithContext(ctx).Delete(&model.EbArticle{}, id).Error
}

// Search 搜索文章（混合 MySQL + Elasticsearch）
func (r *EbArticleRepository) Search(ctx context.Context, keyword string) ([]*model.EbArticle, int64, error) {
	return r.es.Search(ctx, keyword)
}
