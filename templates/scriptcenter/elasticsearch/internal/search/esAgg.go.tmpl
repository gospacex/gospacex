package search

import (
	"encoding/json"
)

// Aggs 聚合操作
type Aggs struct {
	client    *elasticsearch.Client
	indexName string
}

// NewAggs 创建聚合操作
func NewAggs(client *elasticsearch.Client, indexName string) *Aggs {
	return &Aggs{client: client, indexName: indexName}
}

// TermsAgg 词条聚合
func TermsAgg(field string, size int) map[string]interface{} {
	return map[string]interface{}{
		"terms": map[string]interface{}{
			"field": field,
			"size":  size,
		},
	}
}

// DateHistAgg 日期直方图聚合
func DateHistAgg(field string, interval string) map[string]interface{} {
	return map[string]interface{}{
		"date_histogram": map[string]interface{}{
			"field":    field,
			"calendar_interval": interval,
		},
	}
}

