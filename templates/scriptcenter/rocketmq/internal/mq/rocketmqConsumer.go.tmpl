package mq

import (
	"context"
	"encoding/json"
	"fmt"

	"github.com/apache/rocketmq-client-go/v2"
	"github.com/apache/rocketmq-client-go/v2/consumer"
	"github.com/apache/rocketmq-client-go/v2/primitive"
	"{{.ProjectName}}/internal/model"
)

// MessageHandler 消息处理函数类型
type MessageHandler func(*model.EbArticle) error

// RocketmqConsumer RocketMQ 消费者
type RocketmqConsumer struct {
	consumer       rocketmq.PushConsumer
	topic         string
	consumerGroup string
	nameServer    string
}

// NewRocketmqConsumer 创建消费者
func NewRocketmqConsumer(nameServer, topic, consumerGroup string) (rocketmq.PushConsumer, error) {
	c, err := rocketmq.NewPushConsumer(
		consumer.WithGroupName(consumerGroup),
		consumer.WithNameServer(nameServer),
	)
	if err != nil {
		return nil, fmt.Errorf("create consumer: %w", err)
	}

	return &RocketmqConsumer{
		consumer:       c,
		topic:         topic,
		consumerGroup: consumerGroup,
		nameServer:    nameServer,
	}, nil
}

// Consume 开始消费
func (c *RocketmqConsumer) Consume(ctx context.Context, handler MessageHandler) error {
	err := c.consumer.Subscribe(c.topic, consumer.MessageListenerFunc(func(ctx context.Context, msg *primitive.MessageExt) error {
		var article model.EbArticle
		if err := json.Unmarshal(msg.Body, &article); err != nil {
			fmt.Printf("Failed to unmarshal message: %v, skipping\n", err)
			return nil
		}

		return handler(&article)
	})

	if err != nil {
		return fmt.Errorf("subscribe topic: %w", err)
	}

	<-ctx.Done()
	return c.consumer.Shutdown()
}

// IsHealthy 检查健康
func (c *RocketmqConsumer) IsHealthy() error {
	if c.consumer == nil {
		return fmt.Errorf("consumer not initialized")
	}
	return nil
}
