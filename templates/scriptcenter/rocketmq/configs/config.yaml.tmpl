# {{.ProjectName}} - Script Center with RocketMQ Configuration

app:
  name: {{.ProjectName}}
  environment: development

# 数据库配置
database:
  types: [{{range .DB}}{{.}}, {{end}}]
{{- if .MySQL}}
  mysql:
    host: {{.MySQLHost}}
    port: {{.MySQLPort}}
    user: {{.MySQLUser}}
    password: {{.MySQLPassword}}
    database: {{.MySQLDatabase}}
{{end}}

# RocketMQ 配置
rocketmq:
  enabled: true
  name_server: localhost:9876
  topic: article-events
  consumer_group: {{.ProjectName}}-group
