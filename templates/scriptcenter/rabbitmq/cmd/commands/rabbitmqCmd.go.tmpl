package commands

import (
	"fmt"

	"{{.ProjectName}}/internal/service"
	"github.com/spf13/cobra"
)

var (
	consumer bool
	producer bool
)

// rabbitmqCmd RabbitMQ 管理命令
var rabbitmqCmd = &cobra.Command{
	Use:   "rabbitmq",
	Short: "RabbitMQ 连接和状态检查",
	Long:  `检查 RabbitMQ 连接状态，查看消费者信息`,
	RunE: func(cmd *cobra.Command, args []string) error {
		if consumer {
			if err := service.CheckConsumerHealth(); err != nil {
				return fmt.Errorf("consumer health check failed: %w", err)
			}
			fmt.Println("✓ RabbitMQ consumers are healthy")
		}

		if producer {
			if err := service.CheckProducerHealth(); err != nil {
				return fmt.Errorf("producer health check failed: %w", err)
			}
			fmt.Println("✓ RabbitMQ producers are healthy")
		}

		return nil
	},
}

func init() {
	rabbitmqCmd.Flags().BoolVar(&consumer, "consumer", false, "Check consumer health")
	rabbitmqCmd.Flags().BoolVar(&producer, "producer", false, "Check producer health")
	rootCmd.AddCommand(rabbitmqCmd)
}
