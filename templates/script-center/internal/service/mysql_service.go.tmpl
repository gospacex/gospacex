// MySQLService MySQL service layer
type MySQLService struct {
	repo *repository.MySQLRepository
}

// NewMySQLService creates a new MySQL service instance
func NewMySQLService(repo *repository.MySQLRepository) *MySQLService {
	return &MySQLService{repo: repo}
}

// Create creates a new entity
func (s *MySQLService) Create(ctx context.Context, entity interface{}) error {
	// Add business logic here (validation, logging, etc.)
	return s.repo.Create(ctx, entity)
}

// GetByID retrieves an entity by ID
func (s *MySQLService) GetByID(ctx context.Context, id int64) (interface{}, error) {
	return s.repo.GetByID(ctx, id)
}

// Update updates an entity
func (s *MySQLService) Update(ctx context.Context, entity interface{}) error {
	// Add business logic here
	return s.repo.Update(ctx, entity)
}

// Delete deletes an entity by ID
func (s *MySQLService) Delete(ctx context.Context, id int64) error {
	// Add business logic here (cascade deletes, etc.)
	return s.repo.Delete(ctx, id)
}

// List retrieves a list of entities with pagination
func (s *MySQLService) List(ctx context.Context, limit, offset int) ([]interface{}, error) {
	return s.repo.List(ctx, limit, offset)
}
