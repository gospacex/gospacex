package repository

import (
	"context"
	"fmt"

	"{{.ProjectName}}/pkg/database"
	"gorm.io/gorm"
)

// MySQLRepository MySQL repository implementation
type MySQLRepository struct {
	db *gorm.DB
}

// NewMySQLRepository creates a new MySQL repository instance
func NewMySQLRepository() *MySQLRepository {
	return &MySQLRepository{db: database.MySQLDB}
}

// Create creates a new entity in MySQL
func (r *MySQLRepository) Create(ctx context.Context, entity interface{}) error {
	return r.db.WithContext(ctx).Create(entity).Error
}

// GetByID retrieves an entity by ID from MySQL
func (r *MySQLRepository) GetByID(ctx context.Context, id int64) (interface{}, error) {
	var entity interface{}
	err := r.db.WithContext(ctx).First(&entity, id).Error
	if err != nil {
		if err == gorm.ErrRecordNotFound {
			return nil, fmt.Errorf("record not found: %w", err)
		}
		return nil, fmt.Errorf("failed to get entity: %w", err)
	}
	return entity, nil
}

// Update updates an entity in MySQL
func (r *MySQLRepository) Update(ctx context.Context, entity interface{}) error {
	return r.db.WithContext(ctx).Save(entity).Error
}

// Delete deletes an entity by ID from MySQL
func (r *MySQLRepository) Delete(ctx context.Context, id int64) error {
	return r.db.WithContext(ctx).Delete(&gorm.Model{ID: uint(id)}).Error
}

// List retrieves a list of entities from MySQL with pagination
func (r *MySQLRepository) List(ctx context.Context, limit, offset int) ([]interface{}, error) {
	var entities []interface{}
	err := r.db.WithContext(ctx).Limit(limit).Offset(offset).Find(&entities).Error
	if err != nil {
		return nil, fmt.Errorf("failed to list entities: %w", err)
	}
	return entities, nil
}
