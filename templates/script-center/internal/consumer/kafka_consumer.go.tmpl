// NewOrderEventHandler 创建订单事件处理器
func NewOrderEventHandler() *OrderEventHandler {
	return &OrderEventHandler{}
}

// Handle 处理消息 (实现 MessageHandler 接口)
func (h *OrderEventHandler) Handle(ctx context.Context, msg string) error {
	log.Printf("Received order message: %s", msg)

	// 解析消息
	var event struct {
		Event   string          `json:"event"`
		OrderID int64           `json:"order_id"`
		Data    json.RawMessage `json:"data"`
	}
	if err := json.Unmarshal([]byte(msg), &event); err != nil {
		log.Printf("Failed to parse message: %v", err)
		return err
	}

	// 根据事件类型处理
	switch event.Event {
	case "order.created":
		return h.handleOrderCreated(ctx, event.OrderID, event.Data)
	case "order.updated":
		return h.handleOrderUpdated(ctx, event.OrderID, event.Data)
	case "order.deleted":
		return h.handleOrderDeleted(ctx, event.OrderID)
	default:
		log.Printf("Unknown event type: %s", event.Event)
	}

	return nil
}

