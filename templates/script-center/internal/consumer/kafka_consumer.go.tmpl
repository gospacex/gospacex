// StartKafkaConsumer 启动 Kafka 消费者
func StartKafkaConsumer(cfg middleware.KafkaConfig, handler middleware.MessageHandler) (*middleware.KafkaConsumer, error) {
	consumer, err := middleware.NewKafkaConsumer(cfg, handler)
	if err != nil {
		return nil, err
	}

	go func() {
		if err := consumer.Consume(context.Background()); err != nil {
			log.Printf("Consumer error: %v", err)
		}
	}()

	log.Println("Kafka consumer started")
	return consumer, nil
}
