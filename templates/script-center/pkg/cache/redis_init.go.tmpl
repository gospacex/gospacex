// Package cache provides Redis cache initialization for the script center
package cache

import (
	"context"
	"fmt"
	"time"

	"{{.GoModule}}/pkg/config"
	"github.com/redis/go-redis/v9"
)

// RedisClient 全局 Redis 客户端
var RedisClient *redis.Client

// InitRedis initializes Redis client with connection pool
// cfg: configuration with Redis connection details
// Returns error if connection fails
func InitRedis(cfg config.Config) error {
	// Use configured address or default to localhost:6379
	addr := cfg.Redis.Addr
	if addr == "" {
		addr = "localhost:6379"
	}

	// Create Redis client with connection pool options
	client := redis.NewClient(&redis.Options{
		Addr:     addr,
		Password: cfg.Redis.Password,
		DB:       cfg.Redis.DB,
		PoolSize: cfg.Redis.PoolSize,
	})

	if client == nil {
		return fmt.Errorf("failed to create Redis client")
	}

	// Test connection with Ping (5 second timeout)
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	_, err := client.Ping(ctx).Result()
	if err != nil {
		return fmt.Errorf("failed to connect to Redis: %w", err)
	}

	// Assign to global variable
	RedisClient = client

	fmt.Println("Redis connected successfully")
	return nil
}

// GetRedisClient returns the global Redis client
func GetRedisClient() *redis.Client {
	return RedisClient
}

// CloseRedis closes the Redis connection
// Should be called on application shutdown
func CloseRedis() error {
	if RedisClient != nil {
		return RedisClient.Close()
	}
	return nil
}
