// TestPrometheusConfig_Validation tests Prometheus configuration validation
func TestPrometheusConfig_Validation(t *testing.T) {
	tests := []struct {
		name    string
		config  PrometheusConfig
		wantErr bool
		errMsg  string
	}{
		{
			name: "valid config",
			config: PrometheusConfig{
				Enabled: true,
				Path:    "/metrics",
				Port:    9090,
			},
			wantErr: false,
		},
		{
			name: "port too low",
			config: PrometheusConfig{
				Enabled: true,
				Path:    "/metrics",
				Port:    0,
			},
			wantErr: true,
			errMsg:  "port must be between 1 and 65535",
		},
		{
			name: "port too high",
			config: PrometheusConfig{
				Enabled: true,
				Path:    "/metrics",
				Port:    70000,
			},
			wantErr: true,
			errMsg:  "port must be between 1 and 65535",
		},
		{
			name: "empty path",
			config: PrometheusConfig{
				Enabled: true,
				Path:    "",
				Port:    9090,
			},
			wantErr: true,
			errMsg:  "path cannot be empty",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := validatePrometheusConfig(tt.config)
			if tt.wantErr {
				assert.Error(t, err)
				if tt.errMsg != "" {
					assert.Contains(t, err.Error(), tt.errMsg)
				}
			} else {
				assert.NoError(t, err)
			}
		})
	}
}

