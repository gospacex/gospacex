// TestKafkaConfig_Validation tests Kafka configuration validation
func TestKafkaConfig_Validation(t *testing.T) {
	tests := []struct {
		name    string
		config  KafkaConfig
		wantErr bool
		errMsg  string
	}{
		{
			name: "valid config",
			config: KafkaConfig{
				Enabled:   true,
				Brokers:   []string{"localhost:9092"},
				Topic:     "test-topic",
				GroupName: "test-group",
			},
			wantErr: false,
		},
		{
			name: "empty brokers",
			config: KafkaConfig{
				Enabled:   true,
				Brokers:   []string{},
				Topic:     "test-topic",
				GroupName: "test-group",
			},
			wantErr: true,
			errMsg:  "brokers cannot be empty",
		},
		{
			name: "empty topic",
			config: KafkaConfig{
				Enabled:   true,
				Brokers:   []string{"localhost:9092"},
				Topic:     "",
				GroupName: "test-group",
			},
			wantErr: true,
			errMsg:  "topic cannot be empty",
		},
		{
			name: "nil brokers",
			config: KafkaConfig{
				Enabled:   true,
				Brokers:   nil,
				Topic:     "test-topic",
				GroupName: "test-group",
			},
			wantErr: true,
			errMsg:  "brokers cannot be empty",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := validateKafkaConfig(tt.config)
			if tt.wantErr {
				assert.Error(t, err)
				if tt.errMsg != "" {
					assert.Contains(t, err.Error(), tt.errMsg)
				}
			} else {
				assert.NoError(t, err)
			}
		})
	}
}

