package middleware

import (
	"context"
	"encoding/json"
	"fmt"
	"log"
	"time"

	"github.com/rabbitmq/amqp091-go"
)

// ==================== 基础配置 ====================

// RabbitMQConfig RabbitMQ 配置
type RabbitMQConfig struct {
	Enabled    bool          `yaml:"enabled" json:"enabled"`
	URL        string        `yaml:"url" json:"url"`
	Queue      string        `yaml:"queue" json:"queue"`
	Exchange   string        `yaml:"exchange" json:"exchange"`
	MaxRetries int           `yaml:"max_retries" json:"max_retries"`
	RetryDelay time.Duration `yaml:"retry_delay" json:"retry_delay"`
}

// ==================== 生产者 ====================

// RabbitMQProducer RabbitMQ 消息生产者
type RabbitMQProducer struct {
	conn    *amqp091.Connection
	channel *amqp091.Channel
	queue   amqp091.Queue
	config  RabbitMQConfig
}

// NewRabbitMQProducer 创建 RabbitMQ 生产者
func NewRabbitMQProducer(cfg RabbitMQConfig) (*RabbitMQProducer, error) {
	conn, err := amqp091.Dial(cfg.URL)
	if err != nil {
		return nil, fmt.Errorf("dial rabbitmq failed: %w", err)
	}

	channel, err := conn.Channel()
	if err != nil {
		conn.Close()
		return nil, fmt.Errorf("create channel failed: %w", err)
	}

	if cfg.Exchange != "" {
		if err := channel.ExchangeDeclare(
			cfg.Exchange, "direct", true, false, false, false, nil,
		); err != nil {
			return nil, fmt.Errorf("declare exchange failed: %w", err)
		}
	}

	queue, err := channel.QueueDeclare(
		cfg.Queue,
		true,
		false,
		false,
		false,
		amqp091.Table{
			"x-overflow":               "reject-publish",
			"x-queue-mode":             "lazy",
			"x-single-active-consumer": true,
		},
	)
	if err != nil {
		return nil, fmt.Errorf("declare queue failed: %w", err)
	}

	if cfg.Exchange != "" {
		if err := channel.QueueBind(queue.Name, cfg.Queue, cfg.Exchange, false, nil); err != nil {
			return nil, fmt.Errorf("bind queue failed: %w", err)
		}
	}

	log.Printf("RabbitMQ producer connected, queue=%s", queue.Name)
	return &RabbitMQProducer{
		conn:    conn,
		channel: channel,
		queue:   queue,
		config:  cfg,
	}, nil
}

// Publish 发布消息（带重试）
func (p *RabbitMQProducer) Publish(ctx context.Context, body []byte) error {
	var lastErr error
	for i := 0; i < p.config.MaxRetries; i++ {
		err := p.channel.PublishWithContext(
			ctx,
			p.config.Exchange,
			p.queue.Name,
			false,
			false,
			amqp091.Publishing{
				ContentType:  "application/json",
				Body:         body,
				DeliveryMode: amqp091.Persistent,
				Timestamp:    time.Now(),
			},
		)
		if err == nil {
			log.Printf("RabbitMQ message published to %s", p.queue.Name)
			return nil
		}
		lastErr = err
		log.Printf("RabbitMQ publish failed (attempt %d/%d): %v", i+1, p.config.MaxRetries, err)
		time.Sleep(p.config.RetryDelay)
	}

	return fmt.Errorf("publish failed after %d retries: %w", p.config.MaxRetries, lastErr)
}

// PublishJSON 发布 JSON 消息
func (p *RabbitMQProducer) PublishJSON(ctx context.Context, data interface{}) error {
	body, err := json.Marshal(data)
	if err != nil {
		return fmt.Errorf("marshal json failed: %w", err)
	}
	return p.Publish(ctx, body)
}

// Close 关闭生产者
func (p *RabbitMQProducer) Close() error {
	if err := p.channel.Close(); err != nil {
		log.Printf("Close channel error: %v", err)
	}
	if err := p.conn.Close(); err != nil {
		return fmt.Errorf("close connection failed: %w", err)
	}
	log.Println("RabbitMQ producer closed")
	return nil
}

// ==================== 消费者 ====================

// RabbitMQConsumer RabbitMQ 消息消费者
type RabbitMQConsumer struct {
	conn     *amqp091.Connection
	channel  *amqp091.Channel
	queue    amqp091.Queue
	messages <-chan amqp091.Delivery
	handler  MessageHandler
	config   RabbitMQConfig
}

// NewRabbitMQConsumer 创建 RabbitMQ 消费者
func NewRabbitMQConsumer(cfg RabbitMQConfig, handler MessageHandler) (*RabbitMQConsumer, error) {
	conn, err := amqp091.Dial(cfg.URL)
	if err != nil {
		return nil, fmt.Errorf("dial rabbitmq failed: %w", err)
	}

	channel, err := conn.Channel()
	if err != nil {
		conn.Close()
		return nil, err
	}

	if err := channel.Qos(10, 0, false); err != nil {
		return nil, err
	}

	queue, err := channel.QueueDeclare(
		cfg.Queue, true, false, false, false, nil,
	)
	if err != nil {
		return nil, err
	}

	messages, err := channel.Consume(queue.Name, "", false, false, false, false, nil)
	if err != nil {
		return nil, err
	}

	log.Printf("RabbitMQ consumer connected, queue=%s", queue.Name)
	return &RabbitMQConsumer{
		conn:     conn,
		channel:  channel,
		queue:    queue,
		messages: messages,
		handler:  handler,
		config:   cfg,
	}, nil
}

// Consume 消费消息（阻塞调用）
func (c *RabbitMQConsumer) Consume(ctx context.Context) error {
	for {
		select {
		case <-ctx.Done():
			log.Println("RabbitMQ consumer stopping...")
			return c.Close()
		case msg, ok := <-c.messages:
			if !ok {
				log.Println("RabbitMQ message channel closed")
				return nil
			}

			if err := c.handler.Handle(ctx, string(msg.Body)); err != nil {
				log.Printf("Handler error: %v", err)
				msg.Nack(false, false)
				continue
			}

			msg.Ack(false)
		}
	}
}

// Close 关闭消费者
func (c *RabbitMQConsumer) Close() error {
	if err := c.channel.Close(); err != nil {
		log.Printf("Close channel error: %v", err)
	}
	if err := c.conn.Close(); err != nil {
		return fmt.Errorf("close connection failed: %w", err)
	}
	log.Println("RabbitMQ consumer closed")
	return nil
}

	return f(ctx, msg)
}
