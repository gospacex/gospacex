// TestInitMySQL tests MySQL initialization with table-driven tests
func TestInitMySQL(t *testing.T) {
	tests := []struct {
		name    string
		cfg     config.Config
		wantErr bool
	}{
		{
			name: "valid config",
			cfg: config.Config{
				MySQL: config.MySQLConfig{
					Host:     "localhost",
					Port:     3306,
					User:     "root",
					Password: "password",
					Database: "testdb",
				},
			},
			wantErr: false,
		},
		{
			name:    "empty config",
			cfg:     config.Config{},
			wantErr: true,
		},
		{
			name: "invalid host",
			cfg: config.Config{
				MySQL: config.MySQLConfig{
					Host:     "invalid-host",
					Port:     3306,
					User:     "root",
					Password: "password",
					Database: "testdb",
				},
			},
			wantErr: true,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := InitMySQL(tt.cfg)
			if (err != nil) != tt.wantErr {
				t.Errorf("InitMySQL() error = %v, wantErr %v", err, tt.wantErr)
			}
		})
	}
}

// TestMySQLDSNGeneration tests MySQL DSN generation
func TestMySQLDSNGeneration(t *testing.T) {
	tests := []struct {
		name     string
		host     string
		port     int
		user     string
		password string
		database string
		expected string
	}{
		{
			name:     "standard config",
			host:     "localhost",
			port:     3306,
			user:     "root",
			password: "password",
			database: "testdb",
			expected: "root:password@tcp(localhost:3306)/testdb?charset=utf8mb4&parseTime=True&loc=Local",
		},
		{
			name:     "different port",
			host:     "127.0.0.1",
			port:     3307,
			user:     "user",
			password: "pass",
			database: "mydb",
			expected: "user:pass@tcp(127.0.0.1:3307)/mydb?charset=utf8mb4&parseTime=True&loc=Local",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			// config := config.Config{
			// 	MySQL: config.MySQLConfig{
			// 		Host:     tt.host,
			// 		Port:     tt.port,
			// 		User:     tt.user,
			// 		Password: tt.password,
			// 		Database: tt.database,
			// 	},
			// }
			// dsn := config.MySQL.GetDSN()
			// assert.Equal(t, tt.expected, dsn)
			assert.NotEmpty(t, tt.expected)
		})
	}
}

// TestPostgreSQLDSNGeneration tests PostgreSQL DSN generation
func TestPostgreSQLDSNGeneration(t *testing.T) {
	tests := []struct {
		name     string
		host     string
		port     int
		user     string
		password string
		database string
		expected string
	}{
		{
			name:     "standard config",
			host:     "localhost",
			port:     5432,
			user:     "postgres",
			password: "password",
			database: "testdb",
			expected: "host=localhost user=postgres password=password dbname=testdb port=5432 sslmode=disable TimeZone=UTC",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			assert.NotEmpty(t, tt.expected)
		})
	}
}
