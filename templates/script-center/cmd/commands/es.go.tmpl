// esSearchCmd 搜索文档
var esSearchCmd = &cobra.Command{
	Use:   "search [query]",
	Short: "Search documents in Elasticsearch",
	Long:  `在 Elasticsearch 中搜索文档`,
	Args:  cobra.ExactArgs(1),
	RunE: func(cmd *cobra.Command, args []string) error {
		cfg := config.Get()

		client, err := initESClient(cfg)
		if err != nil {
			return err
		}

		if esIndex == "" {
			return fmt.Errorf("--index is required")
		}

		esClient := search.NewESClient(client, esIndex)

		// Build multi_match query
		query := map[string]interface{}{
			"multi_match": map[string]interface{}{
				"query":  args[0],
				"fields": []string{"*"},
			},
		}

		data, err := esClient.Search(query, esFrom, esSize)
		if err != nil {
			return fmt.Errorf("search failed: %w", err)
		}

		fmt.Println(string(data))
		return nil
	},
}

