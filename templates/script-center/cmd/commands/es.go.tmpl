// esBulkCmd 批量索引文档
var esBulkCmd = &cobra.Command{
	Use:   "bulk",
	Short: "Bulk index documents in Elasticsearch",
	Long:  `批量索引文档到 Elasticsearch`,
	RunE: func(cmd *cobra.Command, args []string) error {
		cfg := config.Get()

		client, err := initESClient(cfg)
		if err != nil {
			return err
		}

		if esIndex == "" {
			return fmt.Errorf("--index is required")
		}
		if esData == "" {
			return fmt.Errorf("--data is required (JSON array)")
		}

		var docs []struct {
			ID   string          `json:"id"`
			Doc  json.RawMessage `json:"doc"`
		}
		if err := json.Unmarshal([]byte(esData), &docs); err != nil {
			return fmt.Errorf("invalid JSON data: %w", err)
		}

		esClient := search.NewESClient(client, esIndex)
		bulkDocs := make([]search.BulkDoc, 0, len(docs))
		for _, d := range docs {
			var doc interface{}
			if err := json.Unmarshal(d.Doc, &doc); err != nil {
				return fmt.Errorf("invalid document: %w", err)
			}
			bulkDocs = append(bulkDocs, search.BulkDoc{
				ID:     d.ID,
				Action: "index",
				Doc:    doc,
			})
		}

		if err := esClient.BulkIndex(bulkDocs); err != nil {
			return fmt.Errorf("bulk index failed: %w", err)
		}

		fmt.Printf("✓ Bulk indexed %d documents to index=%s\n", len(bulkDocs), esIndex)
		return nil
	},
}

// initESClient initializes the ES client from config
func initESClient(cfg *config.Config) (*search.ESClient, error) {
	if err := search.InitElasticsearch(*cfg); err != nil {
		log.Printf("ES init error: %v", err)
		return nil, err
	}
	// Return a wrapper that uses the global ESClient
	index := esIndex
	if index == "" && cfg.Elasticsearch.Addr != "" {
		// Default index from config
	}
	return search.NewESClient(search.ESClient.Client(), index), nil
}

func init() {
	rootCmd.AddCommand(esCmd)
	esCmd.AddCommand(esCreateCmd, esGetCmd, esSearchCmd, esDeleteCmd, esBulkCmd)

	// Common flags
	esCmd.PersistentFlags().StringVar(&esIndex, "index", "", "Elasticsearch index name")
	esCmd.PersistentFlags().StringVar(&esID, "id", "", "Document ID")
	esCmd.PersistentFlags().StringVar(&esData, "data", "", "Document data (JSON)")
	esCmd.PersistentFlags().IntVar(&esFrom, "from", 0, "Search offset")
	esCmd.PersistentFlags().IntVar(&esSize, "size", 10, "Search page size")
}