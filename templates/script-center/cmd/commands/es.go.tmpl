package commands

import (
	"context"
	"encoding/json"
	"fmt"
	"log"

	"{{.ProjectName}}/pkg/config"
	"{{.ProjectName}}/pkg/search"
	"github.com/spf13/cobra"
)

var esCmd = &cobra.Command{
	Use:   "es",
	Short: "Elasticsearch management commands",
	Long:  `Elasticsearch 索引和文档管理命令`,
}

var (
	esIndex   string
	esID      string
	esQuery   string
	esFrom    int
	esSize    int
	esData    string
)

// esCreateCmd 创建文档
var esCreateCmd = &cobra.Command{
	Use:   "create",
	Short: "Create a document in Elasticsearch",
	Long:  `在 Elasticsearch 中创建文档`,
	RunE: func(cmd *cobra.Command, args []string) error {
		cfg := config.Get()

		client, err := initESClient(cfg)
		if err != nil {
			return err
		}

		if esIndex == "" {
			return fmt.Errorf("--index is required")
		}
		if esID == "" {
			return fmt.Errorf("--id is required")
		}

		var doc interface{}
		if err := json.Unmarshal([]byte(esData), &doc); err != nil {
			return fmt.Errorf("invalid JSON data: %w", err)
		}

		esClient := search.NewESClient(client, esIndex)
		if err := esClient.IndexDocument(esID, doc); err != nil {
			return fmt.Errorf("create document failed: %w", err)
		}

		fmt.Printf("✓ Document created in index=%s, id=%s\n", esIndex, esID)
		return nil
	},
}

