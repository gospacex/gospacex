.PHONY: build run test clean dev deps fmt lint test-coverage build-linux

# Project variables
BINARY_NAME={{.ProjectName}}
GO=go

# Default target
all: build

# Build the application
build:
	$(GO) build -o bin/$(BINARY_NAME) cmd/main.go

# Run the application
run:
	$(GO) run cmd/main.go start

# Run in development mode
dev:
	$(GO) run cmd/main.go start --env development

# Run tests
test:
	$(GO) test -v ./...

# Run tests with coverage
test-coverage:
	$(GO) test -v ./... -coverprofile=coverage.out
	$(GO) tool cover -html=coverage.out -o coverage.html

# Clean build artifacts
clean:
	rm -rf bin/ coverage.out coverage.html

# Install dependencies
deps:
	$(GO) mod tidy

# Format code
fmt:
	$(GO) fmt ./...

# Run linter
lint:
	golangci-lint run

# Build for Linux (cross-compile)
build-linux:
	CGO_ENABLED=0 GOOS=linux GOARCH=amd64 $(GO) build -o bin/$(BINARY_NAME)-linux cmd/main.go

# Build for macOS
build-darwin:
	CGO_ENABLED=0 GOOS=darwin GOARCH=amd64 $(GO) build -o bin/$(BINARY_NAME)-darwin cmd/main.go

# Help target
help:
	@echo "Usage:"
	@echo "  make build          - Build the application"
	@echo "  make run            - Run the application"
	@echo "  make dev            - Run in development mode"
	@echo "  make test           - Run tests"
	@echo "  make test-coverage  - Run tests with coverage report"
	@echo "  make clean          - Clean build artifacts"
	@echo "  make deps           - Install dependencies"
	@echo "  make fmt            - Format code"
	@echo "  make lint           - Run linter"
	@echo "  make build-linux    - Build for Linux"
	@echo "  make build-darwin   - Build for macOS"
