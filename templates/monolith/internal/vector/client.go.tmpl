package vector

// ZVecConfig ZVec 配置
type ZVecConfig struct {
	Host        string
	Port        int
	Timeout     int
	Collection  string
}

// ZVecClient ZVec 向量数据库客户端
type ZVecClient struct {
	host       string
	port       int
	collection string
}

// NewZVecClient 创建 ZVec 客户端
func NewZVecClient(cfg *ZVecConfig) (*ZVecClient, error) {
	if cfg.Host == "" {
		cfg.Host = "localhost"
	}
	if cfg.Port == 0 {
		cfg.Port = 8080
	}

	return &ZVecClient{
		host:       cfg.Host,
		port:       cfg.Port,
		collection: cfg.Collection,
	}, nil
}

