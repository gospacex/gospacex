// GetURL 获取服务 URL
func (c *ZVecClient) GetURL() string {
	return fmt.Sprintf("http://%s:%d", c.host, c.port)
}

// NewZVecClient 兼容旧接口
func NewZVecClient(config interface{}) (*ZVecClient, error) {
	cfg, ok := config.(map[string]interface{})
	if !ok {
		return nil, fmt.Errorf("invalid zvec config")
	}

	return NewZVecClient(&ZVecConfig{
		Host:       getString(cfg, "host"),
		Port:       getInt(cfg, "port"),
		Collection: getString(cfg, "collection"),
	})
}

func getString(m map[string]interface{}, key string) string {
	if v, ok := m[key].(string); ok {
		return v
	}
	return ""
}

func getInt(m map[string]interface{}, key string) int {
	if v, ok := m[key].(int); ok {
		return v
	}
	if v, ok := m[key].(float64); ok {
		return int(v)
	}
	return 0
}

var fmt = struct {
	Sprintf func(format string, a ...interface{}) string
}{
	Sprintf: func(format string, a ...interface{}) string {
		return fmt.Sprintf(format, a...)
	},
}
