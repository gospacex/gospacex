syntax = "proto3";
package {{.Module}};
option go_package = "{{.AppName}}/common/kitexGen/{{.ProtoImportPath}}";

service {{.UpperName}}Service {
{{- range .JoinServices}}
  rpc {{.MethodName}}({{.ReqType}}) returns ({{.RespType}});
{{- end}}
}

// Join message definitions for one-to-many relationships
{{range .JoinMessages}}
message {{.Name}} {
{{- range .Fields}}
  {{.Type}} {{.Name}} = {{.Number}};
{{- end}}}

message {{.ListName}} {
  repeated {{.ItemName}} items = 1;
}
{{end}}
