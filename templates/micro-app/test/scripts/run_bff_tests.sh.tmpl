#!/bin/bash
# BFF HTTP Test Script
# Usage: bash run_bff_tests.sh

set -e

BFF_PORT={{.BFFPort}}
BFF_HOST=${BFF_HOST:-localhost}
BASE_URL="http://${BFF_HOST}:${BFF_PORT}"

echo "=========================================="
echo "BFF HTTP Testing"
echo "Base URL: ${BASE_URL}"
echo "=========================================="

# 检查服务是否运行
check_service() {
    if ! curl -s "${BASE_URL}/api/v1/{{index .Modules 0}}.RouteName" 2>/dev/null | grep -q "items"; then
        echo "⚠️  Warning: Service may not be running at ${BASE_URL}"
        echo "   Run: cd bffH5 && go run cmd/main.go"
    fi
}

check_service

{{range .Modules}}
echo ""
echo "--- Test: Create {{.UpperName}} ---"
RESPONSE=$(curl -s -X POST "${BASE_URL}/api/v1/{{.RouteName}}s" -H "Content-Type: application/json" -d '{"store_name": "Test Product", "price": 99.9}')
echo "$RESPONSE" | head -c 200
echo ""

# 提取创建的 ID
CREATED_ID=$(echo "$RESPONSE" | grep -o '"id":[0-9]*' | grep -o '[0-9]*' | head -1)
if [ -z "$CREATED_ID" ]; then
    CREATED_ID="3"
fi
echo ""

echo "--- Test: List {{.UpperName}} ---"
curl -s "${BASE_URL}/api/v1/{{.RouteName}}s" | head -c 200
echo ""
echo ""

echo "--- Test: Get {{.UpperName}} (ID=${CREATED_ID}) ---"
curl -s "${BASE_URL}/api/v1/{{.RouteName}}s/${CREATED_ID}" | head -c 200
echo ""
echo ""

echo "--- Test: Update {{.UpperName}} (ID=${CREATED_ID}) ---"
curl -s -X PUT "${BASE_URL}/api/v1/{{.RouteName}}s/${CREATED_ID}" -H "Content-Type: application/json" -d '{"store_name": "Updated Product"}' | head -c 200
echo ""
echo ""

echo "--- Test: Delete {{.UpperName}} (ID=${CREATED_ID}) ---"
curl -s -X DELETE "${BASE_URL}/api/v1/{{.RouteName}}s/${CREATED_ID}" | head -c 200
echo ""
echo ""
{{end}}

{{if .HasJoin}}
echo ""
echo "=========================================="
echo "  JOIN Tests (1t1)"
echo "=========================================="

echo ""
echo "--- Test: Join {{.JoinRouteName}} (ID=3) ---"
curl -s "${BASE_URL}/api/v1/{{.JoinRouteName}}/3" | head -c 500
echo ""
{{end}}

echo "=========================================="
echo "BFF Tests Complete!"
echo "=========================================="