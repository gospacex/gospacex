#!/bin/bash
# Service gRPC Test Script
# Usage: bash run_srv_tests.sh

set -e

SRV_PORT={{.SRVPort}}
SRV_HOST=${SRV_HOST:-localhost}
PROTO_FILE="{{.ProtoPath}}"

echo "=========================================="
echo "Service gRPC Testing"
echo "Target: ${SRV_HOST}:${SRV_PORT}"
echo "=========================================="

# 检查 grpcurl 是否安装
if ! command -v grpcurl &> /dev/null; then
    echo "⚠️  grpcurl not found. Install with:"
    echo "    go install github.com/fullstorydev/grpcurl/cmd/grpcurl@latest"
    exit 1
fi

# 检查服务是否运行
check_service() {
    if ! grpcurl -plaintext "${SRV_HOST}:${SRV_PORT}" list &>/dev/null; then
        echo "⚠️  Warning: Service may not be running at ${SRV_HOST}:${SRV_PORT}"
        echo "   Run: cd srvProduct && go run cmd/main.go"
    fi
}

check_service

echo ""
echo "--- List available services ---"
grpcurl -plaintext "${SRV_HOST}:${SRV_PORT}" list
echo ""

echo "--- Test: ProductService/Create ---"
CREATE_RESP=$(grpcurl -plaintext -d '{}' "${SRV_HOST}:${SRV_PORT}" product.ProductService/Create)
echo "$CREATE_RESP"
CREATED_ID=$(echo "$CREATE_RESP" | grep -o '"id":"[^"]*"' | grep -o '[0-9]*' | head -1)
if [ -z "$CREATED_ID" ]; then
    CREATED_ID="2"
fi
echo ""

echo "--- Test: ProductService/List ---"
grpcurl -plaintext -d '{}' "${SRV_HOST}:${SRV_PORT}" product.ProductService/List
echo ""

echo "--- Test: ProductService/Get (ID=${CREATED_ID}) ---"
grpcurl -plaintext -d "{\"id\": ${CREATED_ID}}" "${SRV_HOST}:${SRV_PORT}" product.ProductService/Get
echo ""

echo "--- Test: ProductService/Update (ID=${CREATED_ID}) ---"
grpcurl -plaintext -d "{\"id\": ${CREATED_ID}, \"store_name\": \"Updated Product\"}" "${SRV_HOST}:${SRV_PORT}" product.ProductService/Update
echo ""

echo "--- Test: ProductService/Delete (ID=${CREATED_ID}) ---"
grpcurl -plaintext -d "{\"id\": ${CREATED_ID}}" "${SRV_HOST}:${SRV_PORT}" product.ProductService/Delete
echo ""

echo "=========================================="
echo "Service Tests Complete!"
echo "=========================================="