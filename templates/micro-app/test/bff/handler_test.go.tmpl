package test

import (
	"encoding/json"
	"net/http"
	"net/http/httptest"
	"strings"
	"testing"

	"github.com/gin-gonic/gin"
	"{{.ModuleName}}/{{.BffDirName}}/internal/router"
)

// Test{{.UpperName}}Handler_List 测试列表接口
func Test{{.UpperName}}Handler_List(t *testing.T) {
	gin.SetMode(gin.TestMode)
	r := router.NewRouter()

	req := httptest.NewRequest(http.MethodGet, "/api/v1/{{.ModuleName}}s", nil)
	w := httptest.NewRecorder()
	r.ServeHTTP(w, req)

	if w.Code != http.StatusOK {
		t.Errorf("expected status 200, got %d", w.Code)
	}

	var resp map[string]interface{}
	if err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {
		t.Errorf("failed to parse response: %v", err)
	}
}

