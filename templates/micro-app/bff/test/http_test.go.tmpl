// newDirectClient 直连 mock gRPC server（绕过 Consul）
func newDirectClient(t *testing.T, grpcAddr string) *rpcclient.{{.UpperModule}}Client {
	t.Helper()
	cli, err := rpcclient.New{{.UpperModule}}ClientDirect(grpcAddr)
	if err != nil {
		t.Fatalf("failed to create direct rpc client: %v", err)
	}
	return cli
}

// setupTestRouter 启动 mock gRPC server + Gin HTTP 路由
func setupTestRouter(t *testing.T) (*gin.Engine, func()) {
	t.Helper()
	gin.SetMode(gin.TestMode)

	// 启动 mock gRPC server
	lis, err := net.Listen("tcp", "127.0.0.1:0")
	if err != nil {
		t.Fatalf("failed to listen: %v", err)
	}
	mockSrv := grpc.NewServer()
	pb.Register{{.UpperModule}}ServiceServer(mockSrv, newMock{{.UpperModule}}Server())
	go mockSrv.Serve(lis)

	addr := lis.Addr().String()
	cli := newDirectClient(t, addr)

	r := gin.New()
	ph := &testable{{.UpperModule}}Handler{client: cli}
{{- range .JoinModules}}
	// 关联模块 {{.}} 需要在 join 场景中添加客户端
{{- end}}
	r.GET("/api/v1/{{.Module}}s", ph.List)
	r.GET("/api/v1/{{.Module}}s/:id", ph.Get)
	r.POST("/api/v1/{{.Module}}s", ph.Create)
	r.PUT("/api/v1/{{.Module}}s/:id", ph.Update)
	r.DELETE("/api/v1/{{.Module}}s/:id", ph.Delete)

	return r, func() {
		cli.Close()
		mockSrv.GracefulStop()
	}
}

