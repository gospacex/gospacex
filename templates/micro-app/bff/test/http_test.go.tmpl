// ========== 测试用例 ==========

func Test{{.UpperModule}}Create(t *testing.T) {
	router, cleanup := setupTestRouter(t)
	defer cleanup()

	body := `{"store_name":"测试","price":99.9,"stock":100}`
	req := httptest.NewRequest(http.MethodPost, "/api/v1/{{.Module}}s", strings.NewReader(body))
	req.Header.Set("Content-Type", "application/json")
	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)

	if w.Code != http.StatusOK {
		t.Fatalf("expected 200, got %d: %s", w.Code, w.Body.String())
	}
	var resp map[string]interface{}
	json.Unmarshal(w.Body.Bytes(), &resp)
	if resp["id"] == nil {
		t.Fatal("expected id in response")
	}
	t.Logf("✅ POST /api/v1/{{.Module}}s → %d", w.Code)
}

func Test{{.UpperModule}}Get(t *testing.T) {
	router, cleanup := setupTestRouter(t)
	defer cleanup()

	body := `{"store_name":"GET测试","price":50.0,"stock":20}`
	req := httptest.NewRequest(http.MethodPost, "/api/v1/{{.Module}}s", strings.NewReader(body))
	req.Header.Set("Content-Type", "application/json")
	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)

	var createResp map[string]interface{}
	json.Unmarshal(w.Body.Bytes(), &createResp)
	id := createResp["id"]

	req = httptest.NewRequest(http.MethodGet, fmt.Sprintf("/api/v1/{{.Module}}s/%v", id), nil)
	w = httptest.NewRecorder()
	router.ServeHTTP(w, req)

	if w.Code != http.StatusOK {
		t.Fatalf("expected 200, got %d", w.Code)
	}
	var getResp map[string]interface{}
	json.Unmarshal(w.Body.Bytes(), &getResp)
	t.Logf("✅ GET /api/v1/{{.Module}}s/%v → %s", id, w.Body.String())
}

func Test{{.UpperModule}}List(t *testing.T) {
	router, cleanup := setupTestRouter(t)
	defer cleanup()

	for i := 0; i < 2; i++ {
		body := fmt.Sprintf(`{"store_name":"列表商品%d","price":%d}`, i+1, (i+1)*10)
		req := httptest.NewRequest(http.MethodPost, "/api/v1/{{.Module}}s", strings.NewReader(body))
		req.Header.Set("Content-Type", "application/json")
		w := httptest.NewRecorder()
		router.ServeHTTP(w, req)
	}

	req := httptest.NewRequest(http.MethodGet, "/api/v1/{{.Module}}s", nil)
	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)

	if w.Code != http.StatusOK {
		t.Fatalf("expected 200, got %d", w.Code)
	}
	var resp map[string]interface{}
	json.Unmarshal(w.Body.Bytes(), &resp)
	items, ok := resp["items"].([]interface{})
	if !ok || len(items) != 2 {
		t.Fatalf("expected 2 items, got %v", resp["items"])
	}
	t.Logf("✅ GET /api/v1/{{.Module}}s → %d items", len(items))
}

func Test{{.UpperModule}}Update(t *testing.T) {
	router, cleanup := setupTestRouter(t)
	defer cleanup()

	body := `{"store_name":"更新前","price":30.0}`
	req := httptest.NewRequest(http.MethodPost, "/api/v1/{{.Module}}s", strings.NewReader(body))
	req.Header.Set("Content-Type", "application/json")
	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)
	var createResp map[string]interface{}
	json.Unmarshal(w.Body.Bytes(), &createResp)
	id := createResp["id"]

	body = `{"store_name":"更新后","price":66.6}`
	req = httptest.NewRequest(http.MethodPut, fmt.Sprintf("/api/v1/{{.Module}}s/%v", id), strings.NewReader(body))
	req.Header.Set("Content-Type", "application/json")
	w = httptest.NewRecorder()
	router.ServeHTTP(w, req)

	if w.Code != http.StatusOK {
		t.Fatalf("expected 200, got %d", w.Code)
	}
	t.Logf("✅ PUT /api/v1/{{.Module}}s/%v → %s", id, w.Body.String())
}

