package handler

import (
	"net/http"

	"myshop/bffH5/internal/middleware/jwt"
	"github.com/gin-gonic/gin"
)

type loginReq struct {
	Username string `json:"username" binding:"required"`
	Password string `json:"password" binding:"required"`
}

type loginResp struct {
	Token     string `json:"token"`
	ExpiresIn int64  `json:"expires_in"`
}

type refreshReq struct {
	Token string `json:"token" binding:"required"`
}

type refreshResp struct {
	Token     string `json:"token"`
	ExpiresIn int64  `json:"expires_in"`
}

var jwtSvc *jwt.JWTService

func SetJWTService(svc *jwt.JWTService) {
	jwtSvc = svc
}

// login 处理用户登录，生成 JWT token
func login(c *gin.Context) {
	var req loginReq
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"code": 400, "message": "invalid request"})
		return
	}

	// TODO: 验证用户名密码（示例中省略）
	// 实际项目中应查询数据库验证用户身份

	claims := &jwt.CustomClaims{
		UserID:   1,
		Username: req.Username,
		Role:     "user",
	}
	token, err := jwtSvc.Generate(claims)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"code": 500, "message": "generate token failed"})
		return
	}

	c.JSON(http.StatusOK, gin.H{
		"code": 200,
		"data": loginResp{
			Token:     token,
			ExpiresIn: int64(jwtSvc.GetExpiry().Seconds()),
		},
	})
}

// refreshToken 处理 token 刷新（以旧换新）
func refreshToken(c *gin.Context) {
	var req refreshReq
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"code": 400, "message": "invalid request"})
		return
	}

	// 使用滑动过期：每次刷新重新计算过期时间
	newToken, err := jwtSvc.Refresh(req.Token, true)
	if err != nil {
		c.JSON(http.StatusUnauthorized, gin.H{"code": 401, "message": "refresh token failed: " + err.Error()})
		return
	}

	c.JSON(http.StatusOK, gin.H{
		"code": 200,
		"data": refreshResp{
			Token:     newToken,
			ExpiresIn: int64(jwtSvc.GetExpiry().Seconds()),
		},
	})
}

// getCurrentUser 获取当前登录用户信息
func getCurrentUser(c *gin.Context) {
	userID, exists := c.Get("user_id")
	if !exists {
		c.JSON(http.StatusUnauthorized, gin.H{"code": 401, "message": "not logged in"})
		return
	}

	username, _ := c.Get("username")
	role, _ := c.Get("role")

	c.JSON(http.StatusOK, gin.H{
		"code": 200,
		"data": gin.H{
			"user_id":  userID,
			"username": username,
			"role":     role,
		},
	})
}

// logout 处理用户登出（使 token 失效）
func logout(c *gin.Context) {
	token := c.GetHeader("Authorization")
	if len(token) > 7 && token[:7] == "Bearer " {
		token = token[7:]
	}

	if err := jwtSvc.Invalidate(token); err != nil {
		c.JSON(http.StatusOK, gin.H{"code": 200, "message": "logout success"})
		return
	}

	c.JSON(http.StatusOK, gin.H{"code": 200, "message": "logout success"})
}

// exampleProtected 示例：需要登录才能访问的接口
func exampleProtected(c *gin.Context) {
	userID, _ := c.Get("user_id")
	username, _ := c.Get("username")

	c.JSON(http.StatusOK, gin.H{
		"code": 200,
		"message": "success",
		"data": gin.H{
			"user_id":  userID,
			"username": username,
			"tip":     "This is a protected endpoint",
		},
	})
}
