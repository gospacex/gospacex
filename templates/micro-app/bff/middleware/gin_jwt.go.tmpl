package middleware

import (
	"strings"
	"time"

	"{{.AppName}}/{{.BFFName}}/pkg/jwt"
	"github.com/gin-gonic/gin"
)

// JWTMiddleware JWT 中间件
func JWTMiddleware(jwtService *jwt.JWT) gin.HandlerFunc {
	return func(c *gin.Context) {
		if jwtService == nil {
			c.Next()
			return
		}

		// 从 Header、Cookie、Query 中提取 Token
		tokenString := extractToken(c)
		if tokenString == "" {
			c.JSON(401, gin.H{"code": 401, "message": "missing token"})
			c.Abort()
			return
		}

		// 解析 Token
		claims, err := jwtService.ParseToken(tokenString)
		if err != nil {
			c.JSON(401, gin.H{"code": 401, "message": "invalid token: " + err.Error()})
			c.Abort()
			return
		}

		// 将用户信息注入 Context
		c.Set("user_id", claims.UserID)
		c.Set("username", claims.Username)
		c.Set("role", claims.Role)
		c.Set("claims", claims)
		c.Next()
	}
}

// RefreshTokenHandler 刷新 Token 处理器
// POST /api/auth/refresh
func RefreshTokenHandler(jwtService *jwt.JWT) gin.HandlerFunc {
	return func(c *gin.Context) {
		if jwtService == nil {
			c.JSON(500, gin.H{"code": 500, "message": "jwt service not initialized"})
			c.Abort()
			return
		}

		var req struct {
			Token string `json:"token" binding:"required"`
		}
		if err := c.ShouldBindJSON(&req); err != nil {
			c.JSON(400, gin.H{"code": 400, "message": "missing token"})
			c.Abort()
			return
		}

		newToken, err := jwtService.RefreshToken(req.Token)
		if err != nil {
			c.JSON(401, gin.H{"code": 401, "message": "token refresh failed: " + err.Error()})
			c.Abort()
			return
		}

		c.JSON(200, gin.H{
			"code":   200,
			"token":  newToken,
			"expire": time.Now().Add(time.Hour).Unix(),
		})
	}
}

// extractToken 从 Header/Cookie/Query 中提取 Token
func extractToken(c *gin.Context) string {
	// 1. 从 Authorization Header 提取 (Bearer xxx)
	authHeader := c.GetHeader("Authorization")
	if authHeader != "" {
		if strings.HasPrefix(authHeader, "Bearer ") {
			return strings.TrimPrefix(authHeader, "Bearer ")
		}
		return authHeader
	}

	// 2. 从 Cookie 提取
	token, err := c.Cookie("token")
	if err == nil && token != "" {
		return token
	}

	// 3. 从 Query 参数提取
	token = c.Query("token")
	if token != "" {
		return token
	}

	return ""
}