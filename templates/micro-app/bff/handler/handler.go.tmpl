}

func New{{.UpperName}}Handler() *{{.UpperName}}Handler {
	cli, err := rpcclient.New{{.UpperName}}Client("127.0.0.1:{{.SrvPort}}")
	if err != nil {
		logger.Business.Errorw("failed to create {{.LowerName}} client", "error", err.Error())
		panic("failed to create {{.LowerName}} client: " + err.Error())
	}
	logger.Business.Infow("{{.UpperName}}Handler initialized", "addr", "127.0.0.1:{{.SrvPort}}")
	return &{{.UpperName}}Handler{client: cli}
}

func (h *{{.UpperName}}Handler) Create(c *gin.Context) {
	requestID, _ := c.Get("requestID")
	start := time.Now()

	logger.Access.Infow("create request start", "method", c.Request.Method, "path", c.Request.URL.Path, "requestID", requestID)
	logger.Business.Infow("create business start", "resource", "{{.LowerName}}", "requestID", requestID)

	req := &pb.Create{{.UpperName}}Request{}
	if err := c.ShouldBindJSON(req); err != nil {
		logger.Access.Errorw("create request bind failed", "error", err.Error(), "requestID", requestID)
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	resp, err := h.client.Create(c.Request.Context(), req)
	if err != nil {
		logger.Access.Errorw("create RPC failed", "error", err.Error(), "requestID", requestID)
		logger.Business.Errorw("create {{.LowerName}} failed", "error", err.Error(), "requestID", requestID)
		logger.Audit.Errorw("audit: create {{.LowerName}} failed", "error", err.Error(), "requestID", requestID)
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	logger.Access.Infow("create request success", "requestID", requestID, "duration", time.Since(start).String())
	logger.Business.Infow("create {{.LowerName}} success", "id", resp.Id, "requestID", requestID, "duration", time.Since(start).String())
	logger.Audit.Infow("audit: create {{.LowerName}} success", "id", resp.Id, "requestID", requestID)

	c.JSON(http.StatusOK, resp)
}

