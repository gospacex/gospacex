package main

import (
	"context"
	"flag"
	"fmt"
	"log"

	"{{.AppName}}/{{.BffDirName}}/internal/router"
	"{{.AppName}}/pkg/config"

	"github.com/cloudwego/hertz/pkg/app/server"
)

var confPath string

func init() {
	flag.StringVar(&confPath, "config", "configs/config.yaml", "config file")
}

func main() {
	flag.Parse()
{{- if .NacosEnabled}}
	cfg, err := config.Load(confPath)
	if err != nil {
		log.Fatal(err)
	}
	if cfg == nil {
		log.Fatal("Config is nil - check if config file exists: " + confPath)
	}
	if nacosCfg, err := config.LoadWithFallback(confPath, &cfg.Nacos); err == nil {
		cfg = nacosCfg
	}
{{- else}}
	cfg, err := config.Load(confPath)
	if err != nil {
		log.Fatal(err)
	}
	if cfg == nil {
		log.Fatal("Config is nil - check if config file exists: " + confPath)
	}
{{- end}}

	h := server.Default(server.WithHostPorts(cfg.Server.Host + ":" + fmt.Sprintf("%d", cfg.Server.Port)))
	router.Register(h)

	log.Printf("BFF starting on %s", cfg.Server.Host + ":" + fmt.Sprintf("%d", cfg.Server.Port))
	h.Run()
}
