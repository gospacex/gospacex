// Execute 执行聚合查询
func (c *AggregateClient) Execute(ctx context.Context, index string, query map[string]interface{}) (*AggregateResult, error) {
	if c.agg == nil {
		return nil, fmt.Errorf("aggregation is required")
	}

	// 构建请求体
	req := map[string]interface{}{
		"aggs": c.agg,
	}

	if query != nil {
		req["query"] = query
	}

	var buf bytes.Buffer
	if err := json.NewEncoder(&buf).Encode(req); err != nil {
		return nil, fmt.Errorf("encode query: %w", err)
	}

	res, err := c.client.es.Search(
		c.client.es.Search.WithContext(ctx),
		c.client.es.Search.WithIndex(index),
		c.client.es.Search.WithBody(&buf),
		c.client.es.Search.WithSize(0), // 聚合查询不需要返回文档
		c.client.es.Search.WithTrackTotalHits(true),
	)
	if err != nil {
		return nil, fmt.Errorf("aggregate search: %w", err)
	}
	defer res.Body.Close()

	if res.IsError() {
		return nil, fmt.Errorf("aggregate search error: %s", res.String())
	}

	var response map[string]interface{}
	if err := json.NewDecoder(res.Body).Decode(&response); err != nil {
		return nil, fmt.Errorf("decode response: %w", err)
	}

	result := &AggregateResult{}

	if aggs, ok := response["aggregations"].(map[string]interface{}); ok {
		result.Aggregations = aggs
	}

	return result, nil
}

// ExecuteRaw 执行原始聚合查询
func (c *AggregateClient) ExecuteRaw(ctx context.Context, index string, query map[string]interface{}) (map[string]interface{}, error) {
	if c.agg == nil {
		return nil, fmt.Errorf("aggregation is required")
	}

	// 直接使用 agg 作为请求体
	var buf bytes.Buffer
	if err := json.NewEncoder(&buf).Encode(c.agg); err != nil {
		return nil, fmt.Errorf("encode aggregation: %w", err)
	}

	res, err := c.client.es.Search(
		c.client.es.Search.WithContext(ctx),
		c.client.es.Search.WithIndex(index),
		c.client.es.Search.WithBody(&buf),
		c.client.es.Search.WithSize(0),
	)
	if err != nil {
		return nil, fmt.Errorf("aggregate search: %w", err)
	}
	defer res.Body.Close()

	if res.IsError() {
		return nil, fmt.Errorf("aggregate search error: %s", res.String())
	}

	var response map[string]interface{}
	if err := json.NewDecoder(res.Body).Decode(&response); err != nil {
		return nil, fmt.Errorf("decode response: %w", err)
	}

	if aggs, ok := response["aggregations"].(map[string]interface{}); ok {
		return aggs, nil
	}

	return nil, fmt.Errorf("aggregations not found in response")
}
