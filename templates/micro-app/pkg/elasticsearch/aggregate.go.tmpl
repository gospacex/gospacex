package elasticsearch

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
)

// AggregateClient 聚合查询客户端
type AggregateClient struct {
	client *Client
	agg    map[string]interface{}
}

// Build 构建聚合查询
func (c *AggregateClient) Build(agg map[string]interface{}) *AggregateClient {
	c.agg = agg
	return c
}

// AddAgg 添加聚合
func (c *AggregateClient) AddAgg(name string, aggType string, field string, opts map[string]interface{}) *AggregateClient {
	if c.agg == nil {
		c.agg = make(map[string]interface{})
	}

	aggDef := map[string]interface{}{
		"terms": map[string]interface{}{
			"field": field,
		},
	}

	// 合并可选参数
	for k, v := range opts {
		aggDef["terms"].(map[string]interface{})[k] = v
	}

	c.agg[name] = aggDef
	return c
}

// AddNestedAgg 添加嵌套聚合
func (c *AggregateClient) AddNestedAgg(name string, agg map[string]interface{}) *AggregateClient {
	if c.agg == nil {
		c.agg = make(map[string]interface{})
	}
	c.agg[name] = agg
	return c
}

