{{if .Otel}}
func UnaryInterceptor(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {
	start := time.Now()

	md, ok := metadata.FromIncomingContext(ctx)
	var traceID string
	if ok {
		propagator := otel.GetTextMapPropagator()
		ctx = propagator.Extract(ctx, propagation.Metadata(md))
		span := trace.SpanContextFromContext(ctx)
		if span.IsValid() {
			traceID = span.TraceID().String()
		}
	}

	spanName := info.FullMethod
	_, span := otel.Tracer("").Start(ctx, spanName)
	defer span.End()

	resp, err := handler(span.Context(), req)

	latency := time.Since(start)
	code := codes.OK
	if err != nil {
		if st, ok := status.FromError(err); ok {
			code = st.Code()
		}
		fields := []interface{}{
			"method", info.FullMethod,
			"status", code.String(),
			"latency", latency.String(),
		}
		if traceID != "" {
			fields = append(fields, "trace_id", traceID)
		}
		logger.Access.Infow("gRPC call", fields...)
		logger.Error.WithContext(span.Context()).Errorw("gRPC error",
			"method", info.FullMethod,
			"error", err.Error(),
			"status", code.String(),
		)
	} else {
		fields := []interface{}{
			"method", info.FullMethod,
			"status", code.String(),
			"latency", latency.String(),
		}
		if traceID != "" {
			fields = append(fields, "trace_id", traceID)
		}
		logger.Access.Infow("gRPC call", fields...)
	}

	return resp, err
}

func StreamInterceptor(srv interface{}, ss grpc.ServerStream, info *grpc.StreamServerInfo, handler grpc.StreamHandler) error {
	start := time.Now()

	ctx := ss.Context()
	md, ok := metadata.FromIncomingContext(ctx)
	var traceID string
	if ok {
		propagator := otel.GetTextMapPropagator()
		ctx = propagator.Extract(ctx, propagation.Metadata(md))
		span := trace.SpanContextFromContext(ctx)
		if span.IsValid() {
			traceID = span.TraceID().String()
		}
	}

	spanName := info.FullMethod
	_, span := otel.Tracer("").Start(ctx, spanName)
	defer span.End()

	err := handler(srv, &serverStreamWrapper{ServerStream: ss, span: span})

	latency := time.Since(start)
	if err != nil {
		fields := []interface{}{
			"method", info.FullMethod,
			"latency", latency.String(),
		}
		if traceID != "" {
			fields = append(fields, "trace_id", traceID)
		}
		logger.Access.Infow("gRPC stream", fields...)
		logger.Error.WithContext(span.Context()).Errorw("gRPC stream error", "method", info.FullMethod, "error", err.Error())
	}

	return err
}

type serverStreamWrapper struct {
	grpc.ServerStream
	span trace.Span
}

func (w *serverStreamWrapper) Context() context.Context {
	return w.span.Context()
}
