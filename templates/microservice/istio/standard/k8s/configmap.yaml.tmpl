apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .ServiceName }}-config
  namespace: {{ .Namespace | default "default" }}
data:
  server.yaml: |
    server:
      service_name: {{ .ServiceName }}
      host: 0.0.0.0
      port: 8888
    
    database:
      mysql:
        enabled: true
        dsn: "${DB_DSN}"
        pool:
          max_idle_conns: 10
          max_open_conns: 100
    
    log:
      level: info
      format: json
