apiVersion: v1
kind: Secret
metadata:
  name: {{ .ServiceName }}-secrets
  namespace: {{ .Namespace | default "default" }}
type: Opaque
stringData:
  # 数据库密码（应使用外部密钥管理）
  DB_PASSWORD: "${DB_PASSWORD}"
  REDIS_PASSWORD: "${REDIS_PASSWORD}"
  
  # TLS 证书
  tls.crt: "${TLS_CERT}"
  tls.key: "${TLS_KEY}"
