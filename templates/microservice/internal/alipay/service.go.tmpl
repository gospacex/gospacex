package alipay

import (
    "context"
    "fmt"

    "github.com/go-pay/gopay/alipay"
)

type Service struct {
    client *alipay.ClientV3
}

func NewService() (*Service, error) {
    client, err := alipay.NewClientV3(AppID, PrivateKey, IsProduction)
    if err != nil {
        return nil, fmt.Errorf("failed to create alipay client: %w", err)
    }
    if err = client.LoadAliPayPublicKey(AliPublicKey); err != nil {
        return nil, fmt.Errorf("failed to load alipay public key: %w", err)
    }
    return &Service{client: client}, nil
}

// GeneratePayURL 生成支付宝支付链接
func (s *Service) GeneratePayURL(ctx context.Context, orderId, totalAmount, subject string) (string, error) {
    bm := map[string]interface{}{
        "out_trade_no": orderId,
        "total_amount": totalAmount,
        "subject":      subject,
        "product_code": ProductCode,
        "notify_url":   NotifyURL,
    }

    var resp alipay.TradePagePayResponse
    _, err := s.client.TradePagePay(ctx, bm, &resp)
    if err != nil {
        return "", fmt.Errorf("failed to generate pay url: %w", err)
    }
    return resp.Body.Data.(map[string]interface{})["qr_code"].(string), nil
}

// HandleNotify 处理支付宝回调
func (s *Service) HandleNotify(ctx context.Context, params map[string]string) (string, error) {
    // 验签需要在HTTP处理器中完成，这里只处理业务逻辑
