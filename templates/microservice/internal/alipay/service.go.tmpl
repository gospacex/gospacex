package alipay

import (
    "context"

    "github.com/go-pay/gopay"
)

type Service struct {
    provider *Provider
}

func NewService(provider *Provider) *Service {
    return &Service{provider: provider}
}

func (s *Service) GeneratePayURL(ctx context.Context, orderId, totalAmount, subject, notifyURL string) (string, error) {
    bm := gopay.BodyMap{}
    bm.Set("out_trade_no", orderId)
    bm.Set("total_amount", totalAmount)
    bm.Set("subject", subject)
    bm.Set("product_code", "FAST_INSTANT_TRADE_PAY")
    bm.Set("notify_url", notifyURL)

    return s.provider.TradePagePay(ctx, bm)
}

func (s *Service) QueryOrder(ctx context.Context, orderId string) (map[string]interface{}, error) {
    bm := gopay.BodyMap{}
    bm.Set("out_trade_no", orderId)

    return s.provider.TradeQuery(ctx, bm)
}

func (s *Service) VerifyCallback(signData, signType string) (bool, error) {
    return s.provider.VerifySign(signData, signType)
}
