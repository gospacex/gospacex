func TestTransferRequest_Validate(t *testing.T) {
	tests := []struct {
		name    string
		req     *TransferRequest
		wantErr bool
	}{
		{
			name: "valid request",
			req: &TransferRequest{
				TrxID:      "trx-001",
				FromUserID: 1,
				ToUserID:   2,
				Amount:     100.0,
			},
			wantErr: false,
		},
		{
			name: "empty trx ID",
			req: &TransferRequest{
				TrxID:      "",
				FromUserID: 1,
				ToUserID:   2,
				Amount:     100.0,
			},
			wantErr: true,
		},
		{
			name: "zero amount",
			req: &TransferRequest{
				TrxID:      "trx-001",
				FromUserID: 1,
				ToUserID:   2,
				Amount:     0,
			},
			wantErr: true,
		},
	}
	
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			// Basic validation
			if tt.req.TrxID == "" && !tt.wantErr {
				t.Error("empty TrxID should be invalid")
			}
			if tt.req.Amount <= 0 && !tt.wantErr {
				t.Error("zero or negative amount should be invalid")
			}
		})
	}
}

