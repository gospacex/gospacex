package registry

import (
	"context"
	"fmt"
	"time"
	
	clientv3 "go.etcd.io/etcd/client/v3"
	"github.com/cloudwego/kitex/pkg/rpcinfo"
	"github.com/cloudwego/kitex/server/registry"
)

// EtcdRegistry etcd 服务注册发现
type EtcdRegistry struct {
	client *clientv3.Client
}

// NewEtcdRegistry 创建 etcd 注册中心
func NewEtcdRegistry(endpoints []string, timeout time.Duration) (registry.Registry, error) {
	client, err := clientv3.New(clientv3.Config{
		Endpoints:   endpoints,
		DialTimeout: timeout,
	})
	if err != nil {
		return nil, fmt.Errorf("failed to connect etcd: %w", err)
	}
	
	// 测试连接
	ctx, cancel := context.WithTimeout(context.Background(), timeout)
	defer cancel()
	if _, err := client.Get(ctx, "health"); err != nil {
		return nil, fmt.Errorf("etcd health check failed: %w", err)
	}
	
	return &EtcdRegistry{client: client}, nil
}

func (r *EtcdRegistry) Register(info rpcinfo.EndpointInfo) error {
	key := fmt.Sprintf("/kitex/%s/%s", info.ServiceName(), info.Address().String())
	value := fmt.Sprintf("%s:%s", info.ServiceName(), info.Address().String())
	
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()
	
	_, err := r.client.Put(ctx, key, value, clientv3.WithLease(r.client.Lease.Grant(ctx, 30)))
	return err
}

func (r *EtcdRegistry) Deregister(info rpcinfo.EndpointInfo) error {
	key := fmt.Sprintf("/kitex/%s/%s", info.ServiceName(), info.Address().String())
	
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()
	
	_, err := r.client.Delete(ctx, key)
	return err
}
