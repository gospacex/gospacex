// ListWithFilter 支持分页和过滤条件的列表查询
func (r *{{.UpperEntityName}}Repo) ListWithFilter(ctx context.Context, req *pb.List{{.UpperEntityName}}Req) ([]*model.{{.UpperEntityName}}, error) {
	start := time.Now()
	logger.Business.Infow("list {{.Module}} with filter", "page", req.Page, "pageSize", req.PageSize)

	query := r.db.WithContext(ctx)
{{- if .HasSoftDelete}}
	query = query.Where("{{.SoftDeleteCol}} = 0")
{{- end}}

	// 分页处理
	page := req.Page
	pageSize := req.PageSize
	if page <= 0 {
		page = 1
	}
	if pageSize <= 0 {
		pageSize = 20
	}
	if pageSize > 100 {
		pageSize = 100
	}
	offset := (page - 1) * pageSize

	var list []*model.{{.UpperEntityName}}
	err := query.Offset(int(offset)).Limit(int(pageSize)).Find(&list).Error
	if err != nil {
		logger.Business.Errorw("list {{.Module}} with filter failed", "error", err.Error())
		return nil, err
	}

	logger.Business.Infow("list {{.Module}} with filter success", "count", len(list), "page", page, "pageSize", pageSize, "duration", time.Since(start).String())
	return list, nil
}

