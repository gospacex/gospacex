package rpcclient

import (
	"context"
	"fmt"
	"time"

	pb "{{.AppName}}/common/kitexGen/{{.TableName}}"

	clientv3 "go.etcd.io/etcd/client/v3"
	"google.golang.org/grpc"
	"google.golang.org/grpc/credentials/insecure"
)

// {{.UpperEntityName}}ServiceClientInterface 定义 gRPC 客户端接口，方便单元测试 mock
type {{.UpperEntityName}}ServiceClientInterface interface {
	Create(ctx context.Context, req *pb.Create{{.UpperEntityName}}Req) (*pb.Create{{.UpperEntityName}}Resp, error)
	Get(ctx context.Context, id {{.PKGoType}}) (*pb.Get{{.UpperEntityName}}Resp, error)
	List(ctx context.Context) (*pb.List{{.UpperEntityName}}Resp, error)
	Update(ctx context.Context, req *pb.Update{{.UpperEntityName}}Req) (*pb.Update{{.UpperEntityName}}Resp, error)
	Delete(ctx context.Context, id {{.PKGoType}}) (*pb.Delete{{.UpperEntityName}}Resp, error)
}

type {{.UpperEntityName}}Client struct {
	conn   *grpc.ClientConn
	client pb.{{.UpperEntityName}}ServiceClient
}

var _ {{.UpperEntityName}}ServiceClientInterface = (*{{.UpperEntityName}}Client)(nil)

func New{{.UpperEntityName}}Client(etcdAddr string) (*{{.UpperEntityName}}Client, error) {
	// 从 Etcd 发现服务
	etcdClient, err := clientv3.New(clientv3.Config{
		Endpoints:   []string{etcdAddr},
		DialTimeout: 5 * time.Second,
	})
	if err != nil {
		return nil, fmt.Errorf("connect to etcd failed: %w", err)
	}
	ctx := context.Background()
	resp, err := etcdClient.Get(ctx, "/services/{{.Module}}/", clientv3.WithPrefix())
	if err != nil || len(resp.Kvs) == 0 {
		return nil, fmt.Errorf("service {{.Module}} not found in etcd")
	}
	srvAddr := string(resp.Kvs[0].Value)

	conn, err := grpc.Dial(srvAddr, grpc.WithTransportCredentials(insecure.NewCredentials()))
	if err != nil {
		return nil, err
	}
	return &{{.UpperEntityName}}Client{conn: conn, client: pb.New{{.UpperEntityName}}ServiceClient(conn)}, nil
}

func (c *{{.UpperEntityName}}Client) Close() error {
	if c.conn != nil {
		return c.conn.Close()
	}
	return nil
}

// New{{.UpperEntityName}}ClientDirect 直接连接（绕过 Etcd，用于测试）
func New{{.UpperEntityName}}ClientDirect(grpcAddr string) (*{{.UpperEntityName}}Client, error) {
	conn, err := grpc.Dial(grpcAddr, grpc.WithTransportCredentials(insecure.NewCredentials()))
	if err != nil {
		return nil, err
	}
	return &{{.UpperEntityName}}Client{conn: conn, client: pb.New{{.UpperEntityName}}ServiceClient(conn)}, nil
}

func (c *{{.UpperEntityName}}Client) Create(ctx context.Context, req *pb.Create{{.UpperEntityName}}Req) (*pb.Create{{.UpperEntityName}}Resp, error) {
	return c.client.Create(ctx, req)
}

func (c *{{.UpperEntityName}}Client) Get(ctx context.Context, id {{.PKGoType}}) (*pb.Get{{.UpperEntityName}}Resp, error) {
	return c.client.Get(ctx, &pb.Get{{.UpperEntityName}}Req{ {{.PKProtoGoName}}: id })
}

func (c *{{.UpperEntityName}}Client) List(ctx context.Context) (*pb.List{{.UpperEntityName}}Resp, error) {
	return c.client.List(ctx, &pb.List{{.UpperEntityName}}Req{})
}

func (c *{{.UpperEntityName}}Client) Update(ctx context.Context, req *pb.Update{{.UpperEntityName}}Req) (*pb.Update{{.UpperEntityName}}Resp, error) {
	return c.client.Update(ctx, req)
}

func (c *{{.UpperEntityName}}Client) Delete(ctx context.Context, id {{.PKGoType}}) (*pb.Delete{{.UpperEntityName}}Resp, error) {
	return c.client.Delete(ctx, &pb.Delete{{.UpperEntityName}}Req{ {{.PKProtoGoName}}: id })
}