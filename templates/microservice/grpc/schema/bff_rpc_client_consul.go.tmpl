package rpcclient

import (
	"context"
	"fmt"

	pb "{{.AppName}}/common/kitexGen/{{.Module}}"

	"github.com/hashicorp/consul/api"
	"google.golang.org/grpc"
	"google.golang.org/grpc/credentials/insecure"
)

type {{.UpperModule}}Client struct {
	conn   *grpc.ClientConn
	client pb.{{.UpperModule}}ServiceClient
}

func New{{.UpperModule}}Client(consulAddr string) (*{{.UpperModule}}Client, error) {
	// 从 Consul 发现服务
	consulConfig := api.DefaultConfig()
	consulConfig.Address = consulAddr
	consulClient, err := api.NewClient(consulConfig)
	if err != nil {
		return nil, fmt.Errorf("connect to consul failed: %w", err)
	}
	services, _, err := consulClient.Health().Service("{{.Module}}", "", true, nil)
	if err != nil || len(services) == 0 {
		return nil, fmt.Errorf("service {{.Module}} not found in consul")
	}
	srvAddr := fmt.Sprintf("%s:%d", services[0].Service.Address, services[0].Service.Port)

	conn, err := grpc.Dial(srvAddr, grpc.WithTransportCredentials(insecure.NewCredentials()))
	if err != nil {
		return nil, err
	}
	return &{{.UpperModule}}Client{conn: conn, client: pb.New{{.UpperModule}}ServiceClient(conn)}, nil
}

func (c *{{.UpperModule}}Client) Close() error {
	if c.conn != nil {
		return c.conn.Close()
	}
	return nil
}

// New{{.UpperModule}}ClientDirect 直接连接（绕过 Consul，用于测试）
func New{{.UpperModule}}ClientDirect(grpcAddr string) (*{{.UpperModule}}Client, error) {
	conn, err := grpc.Dial(grpcAddr, grpc.WithTransportCredentials(insecure.NewCredentials()))
	if err != nil {
		return nil, err
	}
	return &{{.UpperModule}}Client{conn: conn, client: pb.New{{.UpperModule}}ServiceClient(conn)}, nil
}

func (c *{{.UpperModule}}Client) Create(ctx context.Context, req *pb.Create{{.UpperModule}}Req) (*pb.Create{{.UpperModule}}Resp, error) {
	return c.client.Create(ctx, req)
}

func (c *{{.UpperModule}}Client) Get(ctx context.Context, id {{.PKGoType}}) (*pb.Get{{.UpperModule}}Resp, error) {
	return c.client.Get(ctx, &pb.Get{{.UpperModule}}Req{ {{.PKProtoGoName}}: id })
}

func (c *{{.UpperModule}}Client) List(ctx context.Context) (*pb.List{{.UpperModule}}Resp, error) {
	return c.client.List(ctx, &pb.List{{.UpperModule}}Req{})
}

func (c *{{.UpperModule}}Client) Update(ctx context.Context, req *pb.Update{{.UpperModule}}Req) (*pb.Update{{.UpperModule}}Resp, error) {
	return c.client.Update(ctx, req)
}

func (c *{{.UpperModule}}Client) Delete(ctx context.Context, id {{.PKGoType}}) (*pb.Delete{{.UpperModule}}Resp, error) {
	return c.client.Delete(ctx, &pb.Delete{{.UpperModule}}Req{ {{.PKProtoGoName}}: id })
}
