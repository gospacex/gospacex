package main

import (
	"flag"
	"fmt"
	"log"
	"net"

	"{{.AppName}}/pkg/config"
	"{{.AppName}}/pkg/database"
	"{{.AppName}}/{{.SrvDirName}}/internal/handler"
	pb "{{.AppName}}/common/kitexGen/{{.Module}}"

	"github.com/hashicorp/consul/api"
	"google.golang.org/grpc"
	"google.golang.org/grpc/reflection"
)

var confPath string

func init() {
	flag.StringVar(&confPath, "config", "configs/config.yaml", "config file")
}

func main() {
	flag.Parse()
	// 先从本地文件加载，获取 Nacos 配置信息
	cfg, _ := config.Load(confPath)
	// 优先从 Nacos 加载，失败则使用本地配置
	if nacosCfg, err := config.LoadWithFallback(confPath, &cfg.Nacos); err == nil {
		cfg = nacosCfg
	}
	db, _ := database.NewDB(&cfg.Database)
	addr := fmt.Sprintf("%s:%d", cfg.Server.Host, cfg.Server.Port)
	lis, _ := net.Listen("tcp", addr)
	s := grpc.NewServer()
	pb.Register{{.UpperModule}}ServiceServer(s, handler.New{{.UpperModule}}Handler(db))
	reflection.Register(s)

	// Consul 服务注册
	consulConfig := api.DefaultConfig()
	consulConfig.Address = cfg.Registry.Address
	consulClient, err := api.NewClient(consulConfig)
	if err != nil {
		log.Printf("Warning: Failed to connect to Consul: %v", err)
	} else {
		// 注册地址：0.0.0.0 需要替换为可访问地址（consul 不接受 0.0.0.0）
		// Consul 在 Docker 中运行时，需要使用 host.docker.internal 访问宿主机
		regAddr := cfg.Server.Host
		if regAddr == "0.0.0.0" || regAddr == "[::]" {
			regAddr = "host.docker.internal"
		}
		registration := &api.AgentServiceRegistration{
			ID:      "{{.Module}}",
			Name:    "{{.Module}}",
			Port:    cfg.Server.Port,
			Address: regAddr,
			Check: &api.AgentServiceCheck{
				TCP:      fmt.Sprintf("%s:%d", regAddr, cfg.Server.Port),
				Interval: "10s",
				Timeout:  "5s",
			},
		}
		if err := consulClient.Agent().ServiceRegister(registration); err != nil {
			log.Printf("Warning: Failed to register with Consul: %v", err)
		} else {
			log.Printf("Registered with Consul: %s", "{{.Module}}")
		}
	}

	log.Printf("Starting on %s", addr)
	s.Serve(lis)
}
