func (h *{{.UpperEntityName}}Handler) List(ctx context.Context, req *pb.List{{.UpperEntityName}}Req) (*pb.List{{.UpperEntityName}}Resp, error) {
	start := time.Now()
	logger.Business.Infow("handle list {{.Module}}")

	list, err := h.svc.ListWithFilter(ctx, req)
	if err != nil {
		logger.Business.Errorw("list {{.Module}} failed", "error", err.Error())
		return nil, err
	}

	var items []*pb.{{.UpperEntityName}}Item
	for _, m := range list {
		item := &pb.{{.UpperEntityName}}Item{}
		copier.Copy(item, m)
		items = append(items, item)
	}

	logger.Business.Infow("list {{.Module}} success", "count", len(list), "duration", time.Since(start).String())
	return &pb.List{{.UpperEntityName}}Resp{Items: items}, nil
}

