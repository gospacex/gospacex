func (h *{{.UpperEntityName}}Handler) Create(ctx context.Context, req *pb.Create{{.UpperEntityName}}Req) (*pb.Create{{.UpperEntityName}}Resp, error) {
	start := time.Now()
	logger.Business.Infow("handle create {{.Module}}")

	m := &model.{{.UpperEntityName}}{}
	if err := copier.Copy(m, req); err != nil {
		logger.Business.Errorw("copy request to model failed", "error", err.Error())
		return nil, err
	}

	if err := h.svc.Create(ctx, m); err != nil {
		logger.Business.Errorw("create {{.Module}} failed", "error", err.Error())
		return nil, err
	}

	logger.Business.Infow("create {{.Module}} success", "id", m.Id, "duration", time.Since(start).String())
	return &pb.Create{{.UpperEntityName}}Resp{ {{.PKProtoGoName}}: {{.PKRespConvert}} }, nil
}

func (h *{{.UpperEntityName}}Handler) Get(ctx context.Context, req *pb.Get{{.UpperEntityName}}Req) (*pb.Get{{.UpperEntityName}}Resp, error) {
