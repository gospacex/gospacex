package repository

import (
	"context"
	"gorm.io/gorm"
	"{{ .ModuleName }}/domain/entity"
	"{{ .ModuleName }}/domain/repository"
)

// {{ .ModelName }}RepositoryImpl 仓储实现
type {{ .ModelName }}RepositoryImpl struct {
	db *gorm.DB
}

// New{{ .ModelName }}RepositoryImpl 创建仓储实例
func New{{ .ModelName }}RepositoryImpl(db *gorm.DB) repository.{{ .ModelName }}Repository {
	return &{{ .ModelName }}RepositoryImpl{db: db}
}

// Save 保存实体
func (r *{{ .ModelName }}RepositoryImpl) Save(ctx context.Context, e *entity.{{ .ModelName }}) error {
	return r.db.WithContext(ctx).Create(e).Error
}

// FindByID 根据 ID 查找
func (r *{{ .ModelName }}RepositoryImpl) FindByID(ctx context.Context, id int64) (*entity.{{ .ModelName }}, error) {
	var e entity.{{ .ModelName }}
	err := r.db.WithContext(ctx).First(&e, id).Error
	if err != nil {
		return nil, err
	}
	return &e, nil
}

// Update 更新实体
func (r *{{ .ModelName }}RepositoryImpl) Update(ctx context.Context, e *entity.{{ .ModelName }}) error {
	return r.db.WithContext(ctx).Save(e).Error
}

// Delete 删除实体
func (r *{{ .ModelName }}RepositoryImpl) Delete(ctx context.Context, id int64) error {
	return r.db.WithContext(ctx).Delete(&entity.{{ .ModelName }}{}, id).Error
}
