// ============================================================
// 辅助函数
// ============================================================

// extractTimestamp 从 Snowflake ID 中提取时间戳部分
// 标准结构：1bit符号 + 41bit时间戳 + 10bit机器ID + 12bit序列号
func extractTimestamp(id int64) int64 {
	return id >> 22
}

// extractNodeID 从 Snowflake ID 中提取节点 ID（低 10 位）
func extractNodeID(id int64) int64 {
	return (id >> 12) & 0x3FF
}

// extractSequence 从 Snowflake ID 中提取序列号（低 12 位）
func extractSequence(id int64) int64 {
	return id & 0xFFF
}

// appConfig 应用配置结构（供示例测试使用）
type appConfig struct {
	NodeID int64
	Epoch  time.Time
}

// loadConfig 模拟从配置文件读取配置
// 实际项目中可替换为 JSON/YAML/环境变量/数据库等方式加载
func loadConfig() appConfig {
	return appConfig{
		NodeID: 5,
		Epoch:  time.Date(2025, 1, 1, 0, 0, 0, 0, time.UTC),
	}
}

