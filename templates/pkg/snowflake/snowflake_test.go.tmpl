func TestGenerate(t *testing.T) {
	g, err := NewGenerator(Config{NodeID: 1})
	if err != nil {
		t.Fatalf("Failed to create generator: %v", err)
	}

	t.Run("int64 格式", func(t *testing.T) {
		id, err := g.Generate()
		if err != nil {
			t.Fatalf("Generate() error = %v", err)
		}
		if id == 0 {
			t.Errorf("Generate() returned zero ID")
		}
		t.Logf("Int64 ID: %d", id)
	})

	t.Run("字符串格式", func(t *testing.T) {
		idStr, err := g.GenerateString()
		if err != nil {
			t.Fatalf("GenerateString() error = %v", err)
		}
		if idStr == "" {
			t.Errorf("GenerateString() returned empty string")
		}
		t.Logf("String ID: %s", idStr)
	})

	t.Run("Base64 格式", func(t *testing.T) {
		idBase64, err := g.GenerateBase64()
		if err != nil {
			t.Fatalf("GenerateBase64() error = %v", err)
		}
		if idBase64 == "" {
			t.Errorf("GenerateBase64() returned empty string")
		}
		t.Logf("Base64 ID: %s", idBase64)
	})

	t.Run("MustGenerate 不 panic", func(t *testing.T) {
		defer func() {
			if r := recover(); r != nil {
				t.Errorf("MustGenerate() panicked: %v", r)
			}
		}()

		id := g.MustGenerate()
		if id == 0 {
			t.Errorf("MustGenerate() returned zero ID")
		}
		t.Logf("MustGenerate ID: %d", id)

		idStr := g.MustGenerateString()
		if idStr == "" {
			t.Errorf("MustGenerateString() returned empty string")
		}
		t.Logf("MustGenerateString ID: %s", idStr)
	})
}

