// 时间解析测试
// ============================================================

func TestParseTime(t *testing.T) {
	g, err := NewGenerator(Config{NodeID: 1})
	if err != nil {
		t.Fatalf("Failed to create generator: %v", err)
	}

	t.Run("解析时间在合理范围内", func(t *testing.T) {
		id, err := g.Generate()
		if err != nil {
			t.Fatalf("Generate() error = %v", err)
		}
		parsedTime, err := ParseTime(id)
		if err != nil {
			t.Fatalf("ParseTime() error = %v", err)
		}
		now := time.Now()
		if parsedTime.Before(now.Add(-time.Minute)) || parsedTime.After(now.Add(time.Minute)) {
			t.Errorf("ParseTime() = %v, want around %v", parsedTime, now)
		}
		t.Logf("ID: %d, Parsed Time: %v", id, parsedTime)
	})

	t.Run("验证解析时间与生成时间一致", func(t *testing.T) {
		before := time.Now()
		id, _ := g.Generate()
		after := time.Now()
		parsed, _ := ParseTime(id)
		if parsed.Before(before.Add(-time.Millisecond)) || parsed.After(after.Add(time.Millisecond)) {
			t.Errorf("Parsed time %v not within generation window [%v, %v]", parsed, before, after)
		}
	})

	t.Run("解析无效 ID 应返回错误", func(t *testing.T) {
		for _, id := range []int64{0, -1, 123} {
			_, err := ParseTime(id)
			if err == nil {
				t.Errorf("Expected error for invalid ID %d, got nil", id)
			}
		}
	})
}

// ============================================================
// 并发安全测试
// ============================================================

func TestConcurrency(t *testing.T) {
	g, err := NewGenerator(Config{NodeID: 1})
	if err != nil {
		t.Fatalf("Failed to create generator: %v", err)
	}

	const (
		numGoroutines   = 100
		idsPerGoroutine = 100
	)
	idChan := make(chan int64, numGoroutines*idsPerGoroutine)

	for i := 0; i < numGoroutines; i++ {
		go func() {
			for j := 0; j < idsPerGoroutine; j++ {
				id, err := g.Generate()
				if err != nil {
					t.Errorf("Generate() error = %v", err)
					return
				}
				idChan <- id
			}
		}()
	}

	seen := make(map[int64]bool)
	for i := 0; i < numGoroutines*idsPerGoroutine; i++ {
		id := <-idChan
		if seen[id] {
			t.Errorf("Duplicate ID generated: %d", id)
		}
		seen[id] = true
	}
	t.Logf("Successfully generated %d unique IDs concurrently", len(seen))
}

func TestConcurrencyEnhanced(t *testing.T) {
	t.Run("高并发 ID 唯一性压力测试（100 goroutine × 1000 IDs）", func(t *testing.T) {
		g, err := NewGenerator(Config{NodeID: 1})
		if err != nil {
			t.Fatalf("Failed to create generator: %v", err)
		}

		const (
			goroutineCount = 100
			idPerGoroutine = 1000
		)

		var wg sync.WaitGroup
		ids := make(chan int64, goroutineCount*idPerGoroutine)

		for i := 0; i < goroutineCount; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				for j := 0; j < idPerGoroutine; j++ {
					id, err := g.Generate()
					if err != nil {
						t.Errorf("Generate failed: %v", err)
						return
					}
					ids <- id
				}
			}()
		}

		wg.Wait()
		close(ids)

		seen := make(map[int64]bool)
		duplicates := 0
		for id := range ids {
			if seen[id] {
				duplicates++
			}
			seen[id] = true
		}

		if duplicates > 0 {
			t.Errorf("Found %d duplicates out of %d IDs", duplicates, goroutineCount*idPerGoroutine)
		} else {
			t.Logf("Successfully generated %d unique IDs under high concurrency", goroutineCount*idPerGoroutine)
		}
	})
}

// ============================================================
// 时间单调性 & 序列号溢出测试
// ============================================================

func TestTimeMonotonicity(t *testing.T) {
	g, err := NewGenerator(Config{NodeID: 1})
	if err != nil {
		t.Fatalf("Failed to create generator: %v", err)
	}

	id1, _ := g.Generate()
	time.Sleep(2 * time.Millisecond)
	id2, _ := g.Generate()

	if id2 <= id1 {
		t.Errorf("ID should be increasing: id1=%d, id2=%d", id1, id2)
	}
	t.Logf("ID1: %d, ID2: %d (increasing)", id1, id2)
}

func TestSequenceOverflow(t *testing.T) {
	t.Run("同一毫秒内生成超过 4096 个 ID", func(t *testing.T) {
		g, err := NewGenerator(Config{NodeID: 1})
		if err != nil {
			t.Fatalf("Failed to create generator: %v", err)
		}

		startTime := time.Now()
		var lastID int64
		ids := make(map[int64]bool)

		for i := 0; i < 5000; i++ {
			id, err := g.Generate()
			if err != nil {
				t.Fatalf("Failed to generate ID at position %d: %v", i, err)
			}
			if ids[id] {
				t.Errorf("Duplicate ID found at position %d: %d", i, id)
			}
			ids[id] = true
			if id <= lastID {
				t.Logf("Warning: ID not strictly increasing at position %d (may be waiting for next millisecond)", i)
			}
			lastID = id
		}

		elapsed := time.Since(startTime)
		t.Logf("Generated 5000 IDs in %v (avg: %v per ID)", elapsed, elapsed/5000)
		t.Logf("Successfully generated %d unique IDs", len(ids))
	})
}

