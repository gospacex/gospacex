func TestGetEpoch(t *testing.T) {
	epoch := GetEpoch()
	expected := time.Unix(0, 1288834974657*int64(time.Millisecond))
	if epoch != expected {
		t.Errorf("GetEpoch() = %v, want %v", epoch, expected)
	}
}

func TestCustomEpoch(t *testing.T) {
	customEpoch := time.Date(2024, 1, 1, 0, 0, 0, 0, time.UTC)
	g, err := NewGenerator(Config{NodeID: 1, Epoch: customEpoch})
	if err != nil {
		t.Fatalf("Failed to create generator with custom epoch: %v", err)
	}

	id, err := g.Generate()
	if err != nil {
		t.Fatalf("Generate() error = %v", err)
	}

	parsedTime, err := ParseTime(id)
	if err != nil {
		t.Fatalf("ParseTime() error = %v", err)
	}

	if parsedTime.Before(customEpoch) {
		t.Errorf("Parsed time %v should be after custom epoch %v", parsedTime, customEpoch)
	}
	t.Logf("Custom Epoch: %v, Generated ID: %d, Parsed Time: %v", customEpoch, id, parsedTime)
}

func TestEpochBoundary(t *testing.T) {
	t.Run("未来 Epoch 应拒绝或生成失败", func(t *testing.T) {
		futureEpoch := time.Now().Add(24 * time.Hour)
		g, err := NewGenerator(Config{NodeID: 1, Epoch: futureEpoch})
		if err == nil {
			_, genErr := g.Generate()
			if genErr == nil {
				t.Errorf("Expected error when Epoch is in future, but got no error")
			} else {
				t.Logf("Correctly rejected future Epoch at generation: %v", genErr)
			}
		} else {
			t.Logf("Correctly rejected future Epoch at creation: %v", err)
		}
	})

	t.Run("Epoch 为当前时间边界值", func(t *testing.T) {
		now := time.Now().Truncate(time.Millisecond)
		g, err := NewGenerator(Config{NodeID: 1, Epoch: now})
		if err != nil {
			t.Fatalf("Failed to create generator: %v", err)
		}
		id, err := g.Generate()
		if err != nil {
			t.Fatalf("Generate() error = %v", err)
		}
		if id == 0 {
			t.Errorf("Generated ID should not be zero")
		}
		t.Logf("ID with Epoch=now: %d", id)
	})

	t.Run("Epoch 为零值（使用默认）", func(t *testing.T) {
		g, err := NewGenerator(Config{NodeID: 1})
		if err != nil {
			t.Fatalf("Failed to create generator: %v", err)
		}
		id, err := g.Generate()
		if err != nil {
			t.Fatalf("Generate() error = %v", err)
		}
		if id == 0 {
			t.Errorf("Generated ID should not be zero")
		}
		t.Logf("ID with default Epoch: %d", id)
	})

	t.Run("不同 Epoch 相同 NodeID 的 ID 不冲突", func(t *testing.T) {
		epoch1 := time.Date(2024, 1, 1, 0, 0, 0, 0, time.UTC)
		epoch2 := time.Date(2025, 1, 1, 0, 0, 0, 0, time.UTC)
		gen1, _ := NewGenerator(Config{NodeID: 1, Epoch: epoch1})
		gen2, _ := NewGenerator(Config{NodeID: 1, Epoch: epoch2})

		ids := make(map[int64]bool)
		for i := 0; i < 100; i++ {
			id1, _ := gen1.Generate()
			id2, _ := gen2.Generate()
			if ids[id1] {
				t.Errorf("Duplicate ID from generator1: %d", id1)
			}
			if ids[id2] {
				t.Errorf("Duplicate ID from generator2: %d", id2)
			}
			ids[id1] = true
			ids[id2] = true
		}
		t.Logf("200 IDs from two generators with different Epochs: all unique")
	})
}

