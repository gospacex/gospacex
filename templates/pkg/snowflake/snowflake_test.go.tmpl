func TestNewGenerator(t *testing.T) {
	tests := []struct {
		name    string
		nodeID  int64
		epoch   time.Time
		wantErr bool
	}{
		{"valid node ID 0", 0, time.Time{}, false},
		{"valid node ID 1", 1, time.Time{}, false},
		{"valid node ID 1023", 1023, time.Time{}, false},
		{"custom epoch", 1, time.Date(2024, 1, 1, 0, 0, 0, 0, time.UTC), false},
		{"invalid node ID -1", -1, time.Time{}, true},
		{"invalid node ID 1024", 1024, time.Time{}, true},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			g, err := NewGenerator(Config{NodeID: tt.nodeID, Epoch: tt.epoch})
			if (err != nil) != tt.wantErr {
				t.Errorf("NewGenerator() error = %v, wantErr %v", err, tt.wantErr)
				return
			}
			if !tt.wantErr && g == nil {
				t.Errorf("NewGenerator() generator is nil")
			}
		})
	}
}

