func BenchmarkGenerate(b *testing.B) {
	g, err := NewGenerator(Config{NodeID: 1})
	if err != nil {
		b.Fatalf("Failed to create generator: %v", err)
	}

	b.Run("Generate int64", func(b *testing.B) {
		b.ResetTimer()
		for i := 0; i < b.N; i++ {
			g.Generate() //nolint:errcheck
		}
	})

	b.Run("GenerateString", func(b *testing.B) {
		b.ResetTimer()
		for i := 0; i < b.N; i++ {
			g.GenerateString() //nolint:errcheck
		}
	})

	b.Run("GenerateBase64", func(b *testing.B) {
		b.ResetTimer()
		for i := 0; i < b.N; i++ {
			g.GenerateBase64() //nolint:errcheck
		}
	})
}

func BenchmarkGenerateParallel(b *testing.B) {
	g, err := NewGenerator(Config{NodeID: 1})
	if err != nil {
		b.Fatalf("Failed to create generator: %v", err)
	}

	b.RunParallel(func(pb *testing.PB) {
		for pb.Next() {
			g.Generate() //nolint:errcheck
		}
	})
}
