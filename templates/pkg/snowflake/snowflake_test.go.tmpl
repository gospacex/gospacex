func TestGetSetNodeID(t *testing.T) {
	g, err := NewGenerator(Config{NodeID: 1})
	if err != nil {
		t.Fatalf("Failed to create generator: %v", err)
	}

	t.Run("获取节点 ID", func(t *testing.T) {
		if g.GetNodeID() != 1 {
			t.Errorf("GetNodeID() = %v, want 1", g.GetNodeID())
		}
	})

	t.Run("设置合法节点 ID", func(t *testing.T) {
		if err := g.SetNodeID(2); err != nil {
			t.Fatalf("SetNodeID(2) error = %v", err)
		}
		if g.GetNodeID() != 2 {
			t.Errorf("GetNodeID() after SetNodeID() = %v, want 2", g.GetNodeID())
		}
	})

	t.Run("设置非法节点 ID", func(t *testing.T) {
		if err := g.SetNodeID(1024); err == nil {
			t.Errorf("SetNodeID(1024) expected error, got nil")
		}
	})
}

