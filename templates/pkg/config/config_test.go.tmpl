func TestConfig_Validate(t *testing.T) {
	tests := []struct {
		name    string
		cfg     *Config
		wantErr bool
		errMsg  string
	}{
		{
			name: "valid_minimal_config",
			cfg: &Config{
				App: AppConfig{
					Name:        "test-service",
					Environment: "development",
				},
			},
			wantErr: false,
		},
		{
			name: "missing_app_name",
			cfg: &Config{
				App: AppConfig{
					Environment: "development",
				},
			},
			wantErr: true,
			errMsg:  "app.name is required",
		},
		{
			name: "invalid_environment",
			cfg: &Config{
				App: AppConfig{
					Name:        "test-service",
					Environment: "invalid",
				},
			},
			wantErr: true,
			errMsg:  "app.environment must be one of",
		},
		{
			name: "valid_mysql_config",
			cfg: &Config{
				App: AppConfig{
					Name:        "test-service",
					Environment: "development",
				},
				MySQL: MySQLConfig{
					Host:     "localhost",
					Port:     3306,
					User:     "root",
					Password: "password",
					Database: "testdb",
				},
			},
			wantErr: false,
		},
		{
			name: "invalid_mysql_port",
			cfg: &Config{
				App: AppConfig{
					Name:        "test-service",
					Environment: "development",
				},
				MySQL: MySQLConfig{
					Host: "localhost",
					Port: 99999,
					User: "root",
				},
			},
			wantErr: true,
			errMsg:  "port must be between 1 and 65535",
		},
		{
			name: "valid_redis_config",
			cfg: &Config{
				App: AppConfig{
					Name:        "test-service",
					Environment: "development",
				},
				Redis: RedisConfig{
					Addr: "localhost:6379",
					DB:   0,
				},
			},
			wantErr: false,
		},
		{
			name: "invalid_redis_addr",
			cfg: &Config{
				App: AppConfig{
					Name:        "test-service",
					Environment: "development",
				},
				Redis: RedisConfig{
					Addr: "invalid",
				},
			},
			wantErr: true,
			errMsg:  "invalid addr format",
		},
		{
			name: "invalid_redis_db",
			cfg: &Config{
				App: AppConfig{
					Name:        "test-service",
					Environment: "development",
				},
				Redis: RedisConfig{
					Addr: "localhost:6379",
					DB:   20,
				},
			},
			wantErr: true,
			errMsg:  "db must be between 0 and 15",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := tt.cfg.Validate()
			if tt.wantErr {
				assert.Error(t, err)
				if tt.errMsg != "" {
					assert.Contains(t, err.Error(), tt.errMsg)
				}
			} else {
				assert.NoError(t, err)
			}
		})
	}
}

