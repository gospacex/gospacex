func TestLoadFromString(t *testing.T) {
	yamlContent := `
app:
  name: test-service
  environment: development
mysql:
  host: localhost
  port: 3306
  user: root
  password: password
  database: testdb
redis:
  addr: localhost:6379
  db: 0
`

	cfg, err := LoadFromString(yamlContent)
	require.NoError(t, err)
	require.NotNil(t, cfg)

	assert.Equal(t, "test-service", cfg.App.Name)
	assert.Equal(t, "development", cfg.App.Environment)
	assert.Equal(t, "localhost", cfg.MySQL.Host)
	assert.Equal(t, 3306, cfg.MySQL.Port)
	assert.Equal(t, "localhost:6379", cfg.Redis.Addr)
}

func TestLoadFromString_InvalidYAML(t *testing.T) {
	yamlContent := `
app:
  name: test-service
  invalid_yaml: [unclosed
`

	_, err := LoadFromString(yamlContent)
	assert.Error(t, err)
}

func TestDefaultConfig(t *testing.T) {
	cfg := defaultConfig()
	require.NotNil(t, cfg)

	assert.Equal(t, "gpx-service", cfg.App.Name)
	assert.Equal(t, "development", cfg.App.Environment)
	assert.Equal(t, 3306, cfg.MySQL.Port)
	assert.Equal(t, 5432, cfg.PostgreSQL.Port)
	assert.Equal(t, "localhost:6379", cfg.Redis.Addr)
}

func TestSetAndGet(t *testing.T) {
	originalConfig := globalConfig
	defer func() {
		globalConfig = originalConfig
	}()

	testCfg := &Config{
		App: AppConfig{
			Name:        "test-service",
			Environment: "test",
		},
	}

	Set(testCfg)
	cfg := Get()

	assert.Equal(t, "test-service", cfg.App.Name)
	assert.Equal(t, "test", cfg.App.Environment)
}
