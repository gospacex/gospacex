func TestLocalFileLoader_Source(t *testing.T) {
	loader := NewLocalFileLoader("test/path")
	assert.Equal(t, SourceLocalFile, loader.Source())
}

func TestLocalFileLoader_Watch(t *testing.T) {
	loader := NewLocalFileLoader("test/path")
	ch := loader.Watch("test.key")
	// 目前不支持监听，channel 应该已经关闭
	_, ok := <-ch
	assert.False(t, ok, "channel should be closed")
}

func TestExpandEnv(t *testing.T) {
	loader := NewLocalFileLoader("")

	// 测试占位符替换
	os.Setenv("TEST_VAR", "hello")
	defer os.Unsetenv("TEST_VAR")

	result := loader.expandEnv("prefix-${TEST_VAR}-suffix")
	assert.Equal(t, "prefix-hello-suffix", result)

	// 测试无占位符
	result = loader.expandEnv("no-placeholders-here")
	assert.Equal(t, "no-placeholders-here", result)

	// 测试多个占位符
	os.Setenv("VAR1", "foo")
	os.Setenv("VAR2", "bar")
	defer func() {
		os.Unsetenv("VAR1")
		os.Unsetenv("VAR2")
	}()

	result = loader.expandEnv("${VAR1}-${VAR2}")
	assert.Equal(t, "foo-bar", result)

	// 测试未设置的环境变量（替换为空）
	result = loader.expandEnv("prefix-${NOT_EXIST}-suffix")
	assert.Equal(t, "prefix--suffix", result)

	// 测试占位符没有闭合
	result = loader.expandEnv("prefix-${unclosed")
	assert.Equal(t, "prefix-", result)
}

func TestExpandEnv_NoEnvironmentVariables(t *testing.T) {
	loader := NewLocalFileLoader("")

	// 测试纯文本
	result := loader.expandEnv("this is a test")
	assert.Equal(t, "this is a test", result)

	// 测试普通美元符号不是占位符
	result = loader.expandEnv("$100 $abc")
	assert.Equal(t, "$100 $abc", result)
}
