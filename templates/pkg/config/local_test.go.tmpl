package config

import (
	"os"
	"testing"

	"github.com/stretchr/testify/assert"
)

func TestLocalFileLoader_Load(t *testing.T) {
	// 创建临时测试文件
	content := `
app:
  name: test-app
  debug: true
database:
  host: localhost
  port: 3306
  password: ${TEST_DB_PASSWORD}
  enabled: true
`
	tmpFile, err := os.CreateTemp("", "config-*.yaml")
	assert.NoError(t, err)
	defer os.Remove(tmpFile.Name())

	_, err = tmpFile.WriteString(content)
	assert.NoError(t, err)
	tmpFile.Close()

	// 设置环境变量
	os.Setenv("TEST_DB_PASSWORD", "secret-password")
	defer os.Unsetenv("TEST_DB_PASSWORD")

	loader := NewLocalFileLoader(tmpFile.Name())
	data, err := loader.Load()
	assert.NoError(t, err)

	// 验证结果
	assert.Equal(t, "test-app", data["app.name"])
	assert.Equal(t, true, data["app.debug"])
	assert.Equal(t, "localhost", data["database.host"])
	assert.Equal(t, 3306, int(data["database.port"].(float64)))
	assert.Equal(t, "secret-password", data["database.password"])
	assert.Equal(t, true, data["database.enabled"])
}

