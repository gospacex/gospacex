package config

import (
	"os"
	"strings"
)

// EnvLoader 环境变量加载器
type EnvLoader struct {
	prefix string // 可选前缀，例如 "APP_"
}

// NewEnvLoader 创建环境变量加载器
func NewEnvLoader() *EnvLoader {
	return &EnvLoader{
		prefix: "",
	}
}

// NewEnvLoaderWithPrefix 创建带前缀的环境变量加载器
func NewEnvLoaderWithPrefix(prefix string) *EnvLoader {
	return &EnvLoader{
		prefix: prefix,
	}
}

// Source 返回配置来源
func (e *EnvLoader) Source() Source {
	return SourceEnv
}

// Load 加载环境变量
func (e *EnvLoader) Load() (map[string]interface{}, error) {
	result := make(map[string]interface{})

	// 遍历所有环境变量
	for _, env := range os.Environ() {
		parts := strings.SplitN(env, "=", 2)
		if len(parts) != 2 {
			continue
		}
		name := parts[0]
		value := parts[1]

		// 如果有前缀，只加载带前缀的
		if e.prefix != "" && !strings.HasPrefix(name, e.prefix) {
			continue
		}

		// 转换为点分隔键名
		// APP_DATABASE_HOST → database.host
		key := name
		if e.prefix != "" {
			key = strings.TrimPrefix(key, e.prefix)
		}
		key = strings.ToLower(key)
		key = strings.ReplaceAll(key, "_", ".")

		// 存储到结果
		result[key] = convertEnvValue(value)
	}

	return result, nil
}

// Watch 监听环境变量变更（不支持，环境变量不动态变更）
func (e *EnvLoader) Watch(key string) <-chan *ConfigChange {
	ch := make(chan *ConfigChange, 1)
	close(ch)
	return ch
}

// convertEnvValue 尝试转换环境变量字符串到正确类型
func convertEnvValue(s string) interface{} {
	// 尝试布尔
	if s == "true" || s == "True" || s == "TRUE" {
		return true
	}
	if s == "false" || s == "False" || s == "FALSE" {
		return false
	}

	// 尝试整数
	import "strconv"
	if i, err := strconv.Atoi(s); err == nil {
		return i
	}

	// 尝试浮点数
	if f, err := strconv.ParseFloat(s, 64); err == nil {
		return f
	}

	// 默认字符串
	return s
}
