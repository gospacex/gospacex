version: '3.8'

# Docker Compose for Middleware Local Development
# 
# Usage:
#   # Start all middleware services
#   docker-compose up -d
#
#   # Start specific service only
#   docker-compose up -d kafka rabbitmq
#
#   # View logs
#   docker-compose logs -f kafka
#
#   # Stop all
#   docker-compose down
#
#   # Stop and remove volumes
#   docker-compose down -v

services:
{{- if .EnableKafka}}
  # ============================================
  # Kafka - Distributed streaming platform
  # ============================================
  zookeeper:
    image: confluentinc/cp-zookeeper:latest
    container_name: {{.ProjectName}}-zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
      ZOOKEEPER_TICK_TIME: 2000
    ports:
      - "2181:2181"
    networks:
      - middleware-net
    volumes:
      - zookeeper-data:/var/lib/zookeeper/data
      - zookeeper-log:/var/lib/zookeeper/log

  kafka:
    image: confluentinc/cp-kafka:latest
    container_name: {{.ProjectName}}-kafka
    depends_on:
      - zookeeper
    ports:
      - "9092:9092"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 1
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: 1
    networks:
      - middleware-net
    volumes:
      - kafka-data:/var/lib/kafka/data
{{- end}}

{{- if .EnableRabbitMQ}}
  # ============================================
  # RabbitMQ - Message broker
  # ============================================
  rabbitmq:
    image: rabbitmq:3-management
    container_name: {{.ProjectName}}-rabbitmq
    ports:
      - "5672:5672"   # AMQP protocol
      - "15672:15672" # Management UI
    environment:
      RABBITMQ_DEFAULT_USER: guest
      RABBITMQ_DEFAULT_PASS: guest
    networks:
      - middleware-net
    volumes:
      - rabbitmq-data:/var/lib/rabbitmq
{{- end}}

{{- if .EnableRocketMQ}}
  # ============================================
  # RocketMQ - Message queue
  # ============================================
  rocketmq-namesrv:
    image: apache/rocketmq:latest
    container_name: {{.ProjectName}}-rocketmq-namesrv
    ports:
      - "9876:9876"
    environment:
      JAVA_OPT_EXT: "-Xms128m -Xmx128m"
    command: sh mqnamesrv
    networks:
      - middleware-net
    volumes:
      - rocketmq-namesrv-data:/home/rocketmq/logs

  rocketmq-broker:
    image: apache/rocketmq:latest
    container_name: {{.ProjectName}}-rocketmq-broker
    depends_on:
      - rocketmq-namesrv
    ports:
      - "10911:10911"
      - "10909:10909"
    environment:
      JAVA_OPT_EXT: "-Xms128m -Xmx128m"
      NAMESRV_ADDR: rocketmq-namesrv:9876
    command: sh mqbroker
    networks:
      - middleware-net
    volumes:
      - rocketmq-broker-data:/home/rocketmq/logs
{{- end}}

{{- if .EnableJaeger}}
  # ============================================
  # Jaeger - Distributed tracing
  # ============================================
  jaeger:
    image: jaegertracing/all-in-one:latest
    container_name: {{.ProjectName}}-jaeger
    ports:
      - "14268:14268"  # Jaeger HTTP collector
      - "16686:16686"  # Jaeger UI
      - "4317:4317"    # OTLP gRPC
      - "4318:4318"    # OTLP HTTP
    environment:
      COLLECTOR_ZIPKIN_HOST_PORT: ":9411"
    networks:
      - middleware-net
{{- end}}

{{- if .EnableNacos}}
  # ============================================
  # Nacos - Service discovery & configuration
  # ============================================
  nacos:
    image: nacos/nacos-server:latest
    container_name: {{.ProjectName}}-nacos
    ports:
      - "8848:8848"
      - "9848:9848"
    environment:
      MODE: standalone
      SPRING_DATASOURCE_PLATFORM: mysql
      MYSQL_SERVICE_HOST: mysql
      MYSQL_SERVICE_PORT: 3306
      MYSQL_SERVICE_USER: nacos
      MYSQL_SERVICE_PASSWORD: nacos
      MYSQL_SERVICE_DB_NAME: nacos_config
      NACOS_SERVER_PORT: 8848
    networks:
      - middleware-net
    volumes:
      - nacos-data:/home/nacos/data
    depends_on:
      - mysql
{{- end}}

{{- if .EnableApollo}}
  # ============================================
  # Apollo - Configuration management
  # ============================================
  apollo-configservice:
    image: apolloconfig/apollo-configservice:latest
    container_name: {{.ProjectName}}-apollo-configservice
    ports:
      - "8080:8080"
    environment:
      APOLLO_PORTAL_URL: http://localhost:8070
      APOLLO_ADMIN_SERVICE_URL: http://localhost:8080
      SPRING_DATASOURCE_URL: jdbc:mysql://mysql:3306/apolloconfig?characterEncoding=utf8&serverTimezone=Asia/Shanghai
      SPRING_DATASOURCE_USERNAME: apollo
      SPRING_DATASOURCE_PASSWORD: apollo
    networks:
      - middleware-net
    depends_on:
      - mysql
{{- end}}

{{- if .EnablePrometheus}}
  # ============================================
  # Prometheus - Monitoring & alerting
  # ============================================
  prometheus:
    image: prom/prometheus:latest
    container_name: {{.ProjectName}}-prometheus
    ports:
      - "9090:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml
      - prometheus-data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.console.libraries=/usr/share/prometheus/console_libraries'
      - '--web.console.templates=/usr/share/prometheus/consoles'
    networks:
      - middleware-net
{{- end}}

{{- if .EnableConsul}}
  # ============================================
  # Consul - Service mesh & discovery
  # ============================================
  consul:
    image: consul:latest
    container_name: {{.ProjectName}}-consul
    ports:
      - "8500:8500"  # HTTP API
      - "8600:8600/udp"  # DNS
    environment:
      - CONSUL_BIND_INTERFACE=eth0
    command: agent -server -ui -bootstrap-expect=1 -client=0.0.0.0
    networks:
      - middleware-net
    volumes:
      - consul-data:/consul/data
{{- end}}

{{- if .EnableMySQL}}
  # ============================================
  # MySQL - Required by Nacos/Apollo
  # ============================================
  mysql:
    image: mysql:8.0
    container_name: {{.ProjectName}}-mysql
    ports:
      - "3306:3306"
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: nacos_config
      MYSQL_USER: nacos
      MYSQL_PASSWORD: nacos
    networks:
      - middleware-net
    volumes:
      - mysql-data:/var/lib/mysql
      - ./init-scripts:/docker-entrypoint-initdb.d
{{- end}}

# Grafana dashboard (optional)
{{- if .EnableGrafana}}
  grafana:
    image: grafana/grafana:latest
    container_name: {{.ProjectName}}-grafana
    ports:
      - "3000:3000"
    environment:
      GF_SECURITY_ADMIN_USER: admin
      GF_SECURITY_ADMIN_PASSWORD: admin
    networks:
      - middleware-net
    volumes:
      - grafana-data:/var/lib/grafana
    depends_on:
      - prometheus
{{- end}}

networks:
  middleware-net:
    driver: bridge

volumes:
  zookeeper-data:
  zookeeper-log:
  kafka-data:
  rabbitmq-data:
  rocketmq-namesrv-data:
  rocketmq-broker-data:
  nacos-data:
  mysql-data:
  prometheus-data:
  consul-data:
  grafana-data:
